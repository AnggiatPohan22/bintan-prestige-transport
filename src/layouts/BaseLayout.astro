---
import "@styles/global.css";
import SEO from "@components/site/SEO.astro";
import JsonLd from "@components/site/JsonLd.astro";
import Navbar from "@components/site/Navbar.astro";
import Footer from "@components/site/Footer.astro";
import FloatingWhatsApp from "@components/site/FloatingWhatsApp.astro";
import ScrollEffects from "@components/site/ScrollEffects.astro";
import { brandAssets } from "@data/assets";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, schema, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href={brandAssets.favicon} />
    <link rel="apple-touch-icon" sizes="180x180" href={brandAssets.appleTouchIcon} />
    <link rel="manifest" href="/site.webmanifest" />
    <SEO title={title} description={description} canonical={canonical} ogImage={ogImage} noindex={noindex} />
    <JsonLd data={schema} />
  </head>
  <body class="editorial-site">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Navbar />
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>
    <FloatingWhatsApp />
    <Footer />
    <ScrollEffects />
  </body>
</html>
