---
import "../styles/global.css";
import SEO from "../components/common/SEO.astro";
import JsonLd from "../components/common/JsonLd.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
import FloatingWhatsApp from "../components/common/FloatingWhatsApp.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, schema, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} canonical={canonical} ogImage={ogImage} noindex={noindex} />
    <JsonLd data={schema} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Navbar />
    <main id="main-content" class="min-h-screen">
      <slot />
    </main>
    <FloatingWhatsApp />
    <Footer />
  </body>
</html>
