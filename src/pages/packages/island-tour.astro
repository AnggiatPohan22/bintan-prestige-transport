---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/common/Breadcrumb.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import TourItinerary from "../../components/packages/TourItinerary.astro";
import WhatsAppCTA from "../../components/common/WhatsAppCTA.astro";
import TourExperience from "../../components/packages/TourExperience.astro";
import TourFAQ from "../../components/packages/TourFAQ.astro";
import TourHero from "../../components/packages/TourHero.astro";
import TourPackageGrid from "../../components/packages/TourPackageGrid.astro";
import { breadcrumbSchema, packageSchema } from "../../data/schema";

const itinerary = [
  "Private hotel or villa pick up with route confirmation",
  "Scenic drive toward beach, viewpoint, or culture-first route",
  "Main destination stops with flexible pacing and photo time",
  "Optional food, shopping, or sunset stop based on package timing",
  "Private drop off at hotel, ferry terminal, dinner venue, or next destination",
];
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Packages", href: "/packages/island-tour" },
  { label: "Island Tour", href: "/packages/island-tour" },
];
const schema = [...packageSchema("tour"), breadcrumbSchema(breadcrumbs)];
---

<BaseLayout title="Island Tour" description="Premium private island tour packages for beaches, culture, scenic routes, night movement, and custom concierge itineraries." canonical="/packages/island-tour" schema={schema}>
  <TourHero />
  <Breadcrumb items={breadcrumbs} />
  <section id="tour-packages" class="editorial-section-dark">
    <div class="editorial-container">
      <SectionHeader eyebrow="Tour packages" title="Private island routes with premium pacing" description="Choose a starter route, then confirm timing, stops, vehicle fit, and guest preferences through WhatsApp." variant="editorial" />
      <div class="mt-8">
        <TourPackageGrid />
      </div>
    </div>
  </section>
  <section class="editorial-section-dark border-y border-[#bfa46f]/12">
    <div class="editorial-container">
      <SectionHeader eyebrow="Experience" title="Tour moments shaped for private travel" description="The page now supports beach, culture, evening, and custom concierge tour positioning without building a complex tour builder." variant="editorial" />
      <div class="mt-8">
        <TourExperience />
      </div>
    </div>
  </section>
  <section class="editorial-section-warm">
    <div class="editorial-container">
      <SectionHeader eyebrow="Itinerary" title="A flexible tour flow guests can understand quickly" description="This foundation keeps itinerary content clear while leaving room for real stops and CMS-driven details later." tone="light" variant="editorial" />
      <div class="mt-8">
        <TourItinerary items={itinerary} />
      </div>
    </div>
  </section>
  <section class="editorial-section-dark">
    <div class="editorial-container">
      <SectionHeader eyebrow="FAQ" title="Island tour questions answered early" description="Short answers for route flexibility, mixed stops, booking, and private vehicle expectations." variant="editorial" />
      <div class="mt-8">
        <TourFAQ />
      </div>
    </div>
  </section>
  <WhatsAppCTA message="Hello, I want to ask about Island Tour packages." />
</BaseLayout>
