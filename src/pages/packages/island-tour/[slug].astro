---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "@components/core/Breadcrumb.astro";
import PackageBookingForm from "@components/features/booking/PackageBookingForm.astro";
import PackageDetailContent from "@components/features/packages/PackageDetailContent.astro";
import PackageDetailHero from "@components/features/packages/PackageDetailHero.astro";
import WhatsAppCTA from "@components/core/WhatsAppCTA.astro";
import { breadcrumbSchema, createOfferSchema, organizationSchema, localBusinessSchema } from "@data/schema";
import { absoluteUrl } from "@data/seo";
import { tours } from "@data/tours";

export const getStaticPaths = () =>
  tours.map((tour) => ({
    params: { slug: tour.slug },
    props: { tour },
  }));

const { tour } = Astro.props;
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Activities Packages", href: "/packages/activities-packages" },
  { label: tour.title, href: `/packages/activities-packages/${tour.slug}` },
];
const schema = [
  organizationSchema,
  localBusinessSchema,
  {
    "@type": "TouristTrip",
    name: tour.title,
    description: tour.overview,
    image: absoluteUrl(tour.image),
    url: absoluteUrl(`/packages/activities-packages/${tour.slug}`),
    provider: { "@id": organizationSchema["@id"] },
    offers: createOfferSchema({
      name: tour.title,
      description: tour.description,
      priceFrom: tour.priceFrom,
      url: `/packages/activities-packages/${tour.slug}`,
    }),
  },
  breadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={tour.title} description={tour.description} canonical={`/packages/activities-packages/${tour.slug}`} ogImage={tour.image} schema={schema}>
  <PackageDetailHero item={tour} parentLabel="Activities Package" />
  <Breadcrumb items={breadcrumbs} />
  <PackageDetailContent item={tour} tone="activities" />
  <PackageBookingForm item={tour} typeLabel="Activities Package" tone="light" collapsedPreview />
  <WhatsAppCTA
    title={`Ready to plan ${tour.title}?`}
    description="Send your preferred date, pickup point, guest count, and custom route request through WhatsApp."
    message={tour.whatsappMessage}
  />
</BaseLayout>
