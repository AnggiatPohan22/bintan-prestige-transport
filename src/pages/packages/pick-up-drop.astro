---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/common/Breadcrumb.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import RouteList from "../../components/packages/RouteList.astro";
import IncludeExclude from "../../components/packages/IncludeExclude.astro";
import WhatsAppCTA from "../../components/common/WhatsAppCTA.astro";
import TransferFAQ from "../../components/packages/TransferFAQ.astro";
import TransferFleet from "../../components/packages/TransferFleet.astro";
import TransferHero from "../../components/packages/TransferHero.astro";
import TransferProcess from "../../components/packages/TransferProcess.astro";
import { routes } from "../../data/routes";
---

<BaseLayout title="Pick Up & Drop" description="Premium private pick up and drop transfer service for airport, ferry terminal, hotel, dinner, and custom routes.">
  <TransferHero />
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Packages", href: "/packages/pick-up-drop" }, { label: "Pick Up & Drop" }]} />
  <section id="transfer-routes" class="container-page section-padding">
    <SectionHeader eyebrow="Transfer routes" title="Private routes for arrival, departure, and island movement" description="Start from these common route patterns, then confirm final pickup time, waiting needs, luggage, and vehicle fit through WhatsApp." />
    <div class="mt-8">
      <RouteList items={routes} />
    </div>
  </section>
  <section class="border-y border-white/10 bg-[#111827]/45">
    <div class="container-page section-padding">
      <SectionHeader eyebrow="Fleet fit" title="Choose the right transfer vehicle" description="Vehicle options stay premium and practical, with clear capacity and luggage guidance before confirmation." />
      <div class="mt-8">
        <TransferFleet />
      </div>
    </div>
  </section>
  <section class="container-page section-padding">
    <SectionHeader eyebrow="Booking flow" title="From WhatsApp message to private ride" description="No backend booking engine yet. The transfer flow stays fast, clear, and human-confirmed." />
    <div class="mt-8">
      <TransferProcess />
    </div>
  </section>
  <section class="border-y border-white/10 bg-[#111827]/45">
    <div class="container-page section-padding">
      <SectionHeader eyebrow="Details" title="Transfer basics" description="Keep expectations clear before the guest confirms pickup and drop-off timing." />
      <div class="mt-8">
        <IncludeExclude />
      </div>
    </div>
  </section>
  <section class="container-page section-padding">
    <SectionHeader eyebrow="FAQ" title="Transfer questions answered early" description="Short operational answers for route, vehicle, and booking expectations." />
    <div class="mt-8">
      <TransferFAQ />
    </div>
  </section>
  <WhatsAppCTA message="Hello, I want to ask about Pick Up & Drop service." />
</BaseLayout>
