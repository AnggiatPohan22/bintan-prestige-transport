---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/common/Breadcrumb.astro";
import SectionHeader from "../../components/common/SectionHeader.astro";
import RouteList from "../../components/packages/RouteList.astro";
import IncludeExclude from "../../components/packages/IncludeExclude.astro";
import WhatsAppCTA from "../../components/common/WhatsAppCTA.astro";
import { routes } from "../../data/routes";
---

<BaseLayout title="Pick Up & Drop" description="Private pick up and drop taxi transfer placeholder page.">
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Packages", href: "/packages/pick-up-drop" }, { label: "Pick Up & Drop" }]} />
  <section class="container-page section-padding">
    <SectionHeader eyebrow="Taxi transfer" title="Pick Up & Drop" description="STEP 0 route page placeholder for airport, ferry, hotel, and custom taxi transfers." />
    <div class="mt-8">
      <RouteList items={routes} />
    </div>
  </section>
  <section class="bg-slate-50">
    <div class="container-page section-padding">
      <SectionHeader eyebrow="Details" title="Transfer basics" />
      <div class="mt-8">
        <IncludeExclude />
      </div>
    </div>
  </section>
  <WhatsAppCTA message="Hello, I want to ask about Pick Up & Drop service." />
</BaseLayout>
