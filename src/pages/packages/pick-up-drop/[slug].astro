---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/common/Breadcrumb.astro";
import PackageBookingForm from "../../../components/packages/PackageBookingForm.astro";
import PackageDetailContent from "../../../components/packages/PackageDetailContent.astro";
import PackageDetailHero from "../../../components/packages/PackageDetailHero.astro";
import WhatsAppCTA from "../../../components/common/WhatsAppCTA.astro";
import { breadcrumbSchema, organizationSchema, localBusinessSchema } from "../../../data/schema";
import { absoluteUrl } from "../../../data/seo";
import { routes } from "../../../data/routes";
import { transportRoutes } from "../../../data/transportRoutes";

export const getStaticPaths = () =>
  [...routes, ...transportRoutes].map((route) => ({
    params: { slug: route.slug },
    props: { route },
  }));

const { route } = Astro.props;
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Pick Up & Drop", href: "/packages/pick-up-drop" },
  { label: route.title, href: `/packages/pick-up-drop/${route.slug}` },
];
const schema = [
  organizationSchema,
  localBusinessSchema,
  {
    "@type": "Service",
    name: route.title,
    serviceType: "Private taxi transfer",
    description: route.overview,
    image: absoluteUrl(route.image),
    url: absoluteUrl(`/packages/pick-up-drop/${route.slug}`),
    provider: { "@id": organizationSchema["@id"] },
    offers: {
      "@type": "Offer",
      priceSpecification: route.priceFrom,
      availability: "https://schema.org/InStock",
    },
  },
  breadcrumbSchema(breadcrumbs),
];
---

<BaseLayout title={route.title} description={route.description} canonical={`/packages/pick-up-drop/${route.slug}`} ogImage={route.image} schema={schema}>
  <PackageDetailHero item={route} parentLabel="Taxi Transfer Package" showSummaryCard={false} />
  <Breadcrumb items={breadcrumbs} />
  <PackageDetailContent item={route} enableMobileSwipeControls />
  <PackageBookingForm item={route} typeLabel="Taxi Transfer Package" />
  <WhatsAppCTA
    title={`Ready to book ${route.title}?`}
    description="Send your date, pickup point, drop-off plan, guest count, and vehicle request through WhatsApp."
    message={route.whatsappMessage}
  />
</BaseLayout>
