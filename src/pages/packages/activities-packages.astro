---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "@components/core/Breadcrumb.astro";
import SectionHeader from "@components/core/SectionHeader.astro";
import TourItinerary from "@components/features/packages/TourItinerary.astro";
import WhatsAppCTA from "@components/core/WhatsAppCTA.astro";
import TourExperience from "@components/sections/packages/TourExperience.astro";
import TourFAQ from "@components/features/packages/TourFAQ.astro";
import TourHero from "@components/sections/packages/TourHero.astro";
import TourPackageGrid from "@components/features/packages/TourPackageGrid.astro";
import { breadcrumbSchema, packageSchema } from "@data/schema";

const itinerary = [
  "Private pickup with activity timing confirmation",
  "Comfortable transfer to the selected activity location",
  "Activity experience with operator, guide, or driver coordination as needed",
  "Optional food, shopping, beach, or return stop based on package timing",
  "Private drop-off at hotel, ferry terminal, dinner venue, or next destination",
];
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Packages", href: "/packages/activities-packages" },
  { label: "Activities Packages", href: "/packages/activities-packages" },
];
const schema = [...packageSchema("tour"), breadcrumbSchema(breadcrumbs)];
---

<BaseLayout title="Activities Packages" description="Private Bintan activity packages for shooting, mangrove, fireflies, snorkeling, fishing, golf, shopping, spa, beach, and custom tours." canonical="/packages/activities-packages" schema={schema}>
  <TourHero />
  <Breadcrumb items={breadcrumbs} />
  <section id="tour-packages" class="editorial-section-dark">
    <div class="editorial-container">
      <SectionHeader eyebrow="Activities packages" title="Private Bintan activities with flexible pacing" description="Choose an activity package, then confirm timing, location, inclusions, transport, and guest preferences through WhatsApp." variant="editorial" />
      <div class="mt-8">
        <TourPackageGrid />
      </div>
    </div>
  </section>
  <section class="editorial-section-dark border-y border-[#bfa46f]/12">
    <div class="editorial-container">
      <SectionHeader eyebrow="Experience" title="Activity moments shaped for private travel" description="Each activity keeps transport, timing, and guest comfort clear without adding a heavy booking system." variant="editorial" />
      <div class="mt-8">
        <TourExperience />
      </div>
    </div>
  </section>
  <section class="editorial-section-warm">
    <div class="editorial-container">
      <SectionHeader eyebrow="Itinerary" title="A flexible activity flow guests can understand quickly" description="This foundation keeps activity planning clear while leaving room for real operator details and CMS-driven content later." tone="light" variant="editorial" />
      <div class="mt-8">
        <TourItinerary items={itinerary} />
      </div>
    </div>
  </section>
  <section class="editorial-section-dark">
    <div class="editorial-container">
      <SectionHeader eyebrow="FAQ" title="Activities questions answered early" description="Short answers for route flexibility, activity timing, booking, and private vehicle expectations." variant="editorial" />
      <div class="mt-8">
        <TourFAQ />
      </div>
    </div>
  </section>
  <WhatsAppCTA message="Hello, I want to ask about Activities Packages." />
</BaseLayout>
