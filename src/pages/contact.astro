---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "@components/core/Breadcrumb.astro";
import SectionHeader from "@components/core/SectionHeader.astro";
import WhatsAppCTA from "@components/core/WhatsAppCTA.astro";
import ContactCards from "@components/sections/contact/ContactCards.astro";
import ContactHero from "@components/sections/contact/ContactHero.astro";
import ContactSoftSell from "@components/sections/contact/ContactSoftSell.astro";
import WhatsAppPlanner from "@components/features/whatsapp/WhatsAppPlanner.astro";
import { breadcrumbSchema, localBusinessSchema, organizationSchema } from "@data/schema";

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Contact", href: "/contact" },
];
const schema = [organizationSchema, localBusinessSchema, breadcrumbSchema(breadcrumbs)];
---

<BaseLayout title="Contact Bintan Prestige" description="Contact Bintan Prestige for private taxi, transfer, tour, and activity planning in Bintan through WhatsApp, phone, or email." canonical="/contact" schema={schema}>
  <ContactHero />
  <Breadcrumb items={breadcrumbs} />
  <section class="editorial-section-dark">
    <div class="editorial-container">
      <SectionHeader eyebrow="Contact options" title="Reach Bintan Prestige directly" description="Use WhatsApp, phone, or email to ask about private taxi, ferry pickup, airport transfer, tour routes, and activity planning around Bintan." variant="editorial" />
      <div class="mt-8">
        <ContactCards />
      </div>
    </div>
  </section>
  <section class="editorial-section-warm">
    <div class="editorial-container">
      <WhatsAppPlanner />
    </div>
  </section>
  <ContactSoftSell />
  <WhatsAppCTA
    title="Ready to contact Bintan Prestige?"
    description="Use the planner above or send a direct WhatsApp message with your route, date, pickup point, and travel request."
  />
</BaseLayout>
