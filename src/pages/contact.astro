---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/common/Breadcrumb.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import WhatsAppCTA from "../components/common/WhatsAppCTA.astro";
import ContactCards from "../components/contact/ContactCards.astro";
import ContactHero from "../components/contact/ContactHero.astro";
import WhatsAppPlanner from "../components/contact/WhatsAppPlanner.astro";
---

<BaseLayout title="Contact" description="Contact the premium private taxi and island tour service through WhatsApp, phone, or email.">
  <ContactHero />
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Contact" }]} />
  <section class="container-page section-padding">
    <SectionHeader eyebrow="Contact options" title="Reach the travel concierge" description="Keep the first contact path simple while leaving room for future CMS/API-powered contact details." />
    <div class="mt-8">
      <ContactCards />
    </div>
  </section>
  <section class="border-y border-white/10 bg-[#111827]/45">
    <div class="container-page section-padding">
      <WhatsAppPlanner />
    </div>
  </section>
  <WhatsAppCTA title="Need transfer or tour details?" />
</BaseLayout>
