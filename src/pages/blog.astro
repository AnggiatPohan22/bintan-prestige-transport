---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "@components/features/blog/BlogCard.astro";
import Breadcrumb from "@components/core/Breadcrumb.astro";
import WhatsAppCTA from "@components/core/WhatsAppCTA.astro";
import { MessageCircle } from "lucide-react";
import { absoluteUrl } from "@data/seo";
import { blogArticles, blogCategories, blogLocations, blogTags, favoriteBlogArticles } from "@data/blog";
import { breadcrumbSchema, localBusinessSchema, organizationSchema } from "@data/schema";
import { site } from "@data/site";

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
];
const featuredArticle = favoriteBlogArticles[0] ?? blogArticles[0];
const regularArticles = blogArticles;
const serviceHighlights = [
  {
    label: "Private transfer",
    title: "Airport, ferry, resort, and dinner routes",
    description: "Premium point-to-point transport with pickup timing, luggage needs, and vehicle fit confirmed before the trip.",
  },
  {
    label: "Island experience",
    title: "Activities and private tour planning",
    description: "Bintan highlights, mangrove, fireflies, snorkeling, beach stops, spa, shopping, golf, and custom routes shaped around guest pace.",
  },
  {
    label: "WhatsApp concierge",
    title: "Human-first booking support",
    description: "Guests can ask questions, compare routes, request availability, and confirm the right service from one clear WhatsApp thread.",
  },
];
const whatsappHref = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(
  "Hello, I read your Bintan travel blog and want help planning a private taxi or island tour.",
)}`;
const schema = [
  organizationSchema,
  localBusinessSchema,
  {
    "@type": "Blog",
    name: "Bintan Taxi & Island Tour Blog",
    description: "Guides for private taxi transfers, Bintan ferry and airport pickup, island tours, mangrove trips, snorkeling, and travel planning.",
    url: absoluteUrl("/blog"),
    publisher: { "@id": organizationSchema["@id"] },
    blogPost: blogArticles.map((article) => ({
      "@type": "BlogPosting",
      headline: article.title,
      description: article.description,
      image: absoluteUrl(article.heroImage),
      url: absoluteUrl(`/blog/${article.slug}`),
      datePublished: article.publishedAt,
    })),
  },
  breadcrumbSchema(breadcrumbs),
];
---

<BaseLayout
  title="Bintan Taxi & Island Tour Blog"
  description="SEO travel guides for Bintan private taxi transfers, harbour pickup, airport pickup, hotel rides, mangrove tours, snorkeling, and island destinations."
  canonical="/blog"
  ogImage={featuredArticle.heroImage}
  schema={schema}
>
  <section class="blog-hero site-hero-section relative isolate flex min-h-[100svh] overflow-hidden border-b border-white/10 bg-[#0b0c10] text-white">
    <div
      class="blog-hero__image absolute inset-0 -z-20 bg-cover bg-center"
      role="img"
      aria-label="Bintan travel blog editorial hero"
      style={`background-image: url('${featuredArticle.heroImage}');`}
    ></div>
    <div class="blog-hero__shade absolute inset-0 -z-10"></div>
    <div class="site-hero-inner blog-hero__inner container-page relative flex min-h-[100svh] w-full flex-col justify-end py-12 lg:py-16">
      <div class="hero-copy max-w-4xl">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#e2e8f0]/64">Bintan Travel Journal</p>
        <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-[1.05] text-[#e2e8f0] sm:text-5xl lg:text-6xl">
          Taxi guides and island stories for smarter trips.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
          Practical articles for airport pickup, harbour transfer, hotel rides, mangrove routes, snorkeling days, and private Bintan travel planning.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="luxury-btn-primary" href={whatsappHref} target="_blank" rel="noreferrer">
            <MessageCircle className="h-4 w-4" aria-hidden="true" />
            <span>Plan via WhatsApp</span>
          </a>
          <a class="luxury-btn-secondary" href="#latest-guides">
            Read Articles
          </a>
        </div>
      </div>
    </div>
  </section>

  <Breadcrumb items={breadcrumbs} />

  <section id="latest-guides" class="editorial-section-dark border-y border-[#bfa46f]/12">
    <div class="editorial-container">
      <div class="blog-discovery-layout">
        <div class="editorial-card blog-topic-panel blog-browser-panel p-4 sm:p-5" data-blog-filter-panel>
          <div class="flex flex-wrap items-end justify-between gap-3">
            <div>
              <p class="editorial-kicker text-[0.68rem]">Browse topics</p>
              <h2 class="mt-2 text-base font-extrabold leading-tight text-[#f8fafc] sm:text-lg">Filter by topic, place, or guide type.</h2>
            </div>
            <button class="blog-filter-chip" type="button" data-blog-filter="all" data-blog-value="all" aria-pressed="true">All articles</button>
          </div>
          <div class="mt-4 grid gap-3">
            <div class="blog-topic-row">
              <p class="blog-topic-label">Category</p>
              <div class="blog-topic-chips">
                {blogCategories.map((category) => <button class="blog-filter-chip" type="button" data-blog-filter="category" data-blog-value={category} aria-pressed="false">{category}</button>)}
              </div>
            </div>
            <div class="blog-topic-row">
              <p class="blog-topic-label">Location</p>
              <div class="blog-topic-chips">
                {blogLocations.map((location) => <button class="blog-filter-chip" type="button" data-blog-filter="location" data-blog-value={location} aria-pressed="false">{location}</button>)}
              </div>
            </div>
            <div class="blog-topic-row">
              <p class="blog-topic-label">Tags</p>
              <div class="blog-topic-chips">
                {blogTags.slice(0, 12).map((tag) => <button class="blog-filter-chip" type="button" data-blog-filter="tag" data-blog-value={tag} aria-pressed="false">{tag}</button>)}
              </div>
            </div>
          </div>

          <div class="blog-browser-results">
            <div class="flex flex-wrap items-end justify-between gap-3">
              <div>
                <p class="editorial-kicker text-[0.68rem]">Available articles</p>
                <h3 class="mt-2 text-xl font-semibold leading-tight text-[#f8fafc]">Articles matching your travel plan.</h3>
              </div>
              <p class="blog-filter-status" data-blog-filter-status>Showing all articles.</p>
            </div>
            <div class="blog-latest-row mt-6 grid gap-5 md:grid-cols-2" data-blog-list data-page-size="6">
              {regularArticles.map((article) => <BlogCard article={article} showFavoriteBadge={false} />)}
            </div>
            <nav class="blog-pagination mt-7" aria-label="Blog article pagination" data-blog-pagination hidden>
              <button class="blog-pagination-button" type="button" data-blog-prev aria-label="Previous articles page"><span aria-hidden="true">&lsaquo;</span></button>
              <div class="blog-pagination-pages" data-blog-pages></div>
              <button class="blog-pagination-button" type="button" data-blog-next aria-label="Next articles page"><span aria-hidden="true">&rsaquo;</span></button>
            </nav>
          </div>
        </div>
        <aside class="editorial-card blog-favorite-panel p-5 sm:p-6">
          <p class="editorial-kicker">Favorite reads</p>
          <div class="blog-favorite-list mt-4">
            {favoriteBlogArticles.map((article, index) => (
              <a class="blog-favorite-link" href={`/blog/${article.slug}`}>
                <span class="blog-favorite-index">{String(index + 1).padStart(2, "0")}</span>
                <span class="min-w-0">
                  <span class="blog-favorite-title">{article.title}</span>
                  <span class="blog-favorite-location">{article.location}</span>
                </span>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="editorial-section-warm">
    <div class="editorial-container">
      <div class="max-w-3xl">
        <p class="editorial-kicker">Service focus</p>
        <h2 class="editorial-title mt-3 text-[#111827]">What Bintan Prestige helps guests arrange.</h2>
        <p class="editorial-lede mt-4 text-slate-600">
          The blog supports real booking intent by guiding visitors toward private transport, island activities, and clear WhatsApp confirmation.
        </p>
      </div>
      <div class="blog-service-grid mt-8">
        {serviceHighlights.map((item) => (
          <article class="blog-service-card">
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <WhatsAppCTA message="Hello, I read your Bintan travel blog and want help planning a private taxi or island tour." />
</BaseLayout>

<script>
  const filterPanel = document.querySelector<HTMLElement>("[data-blog-filter-panel]");
  const filterList = document.querySelector<HTMLElement>("[data-blog-list]");
  const filterStatus = document.querySelector<HTMLElement>("[data-blog-filter-status]");
  const pagination = document.querySelector<HTMLElement>("[data-blog-pagination]");
  const paginationPages = pagination?.querySelector<HTMLElement>("[data-blog-pages]");
  const previousButton = pagination?.querySelector<HTMLButtonElement>("[data-blog-prev]");
  const nextButton = pagination?.querySelector<HTMLButtonElement>("[data-blog-next]");
  const filterButtons = filterPanel?.querySelectorAll<HTMLButtonElement>("[data-blog-filter]");
  const filterCards = Array.from(filterList?.querySelectorAll<HTMLElement>("[data-blog-card]") ?? []);
  const pageSize = Number(filterList?.dataset.pageSize ?? "6");
  let currentPage = 1;
  let currentFilter = {
    type: "all",
    value: "all",
  };

  const cardMatchesFilter = (card: HTMLElement) => {
    const tags = card.dataset.blogTags?.split("|") ?? [];

    return (
      currentFilter.type === "all" ||
      (currentFilter.type === "category" && card.dataset.blogCategory === currentFilter.value) ||
      (currentFilter.type === "location" && card.dataset.blogLocation === currentFilter.value) ||
      (currentFilter.type === "tag" && tags.includes(currentFilter.value))
    );
  };

  const updatePagination = () => {
    const matchingCards = filterCards.filter(cardMatchesFilter);
    const pageCount = Math.max(1, Math.ceil(matchingCards.length / pageSize));
    currentPage = Math.min(currentPage, pageCount);
    const startIndex = (currentPage - 1) * pageSize;
    const endIndex = startIndex + pageSize;

    filterCards.forEach((card) => {
      card.hidden = true;
    });

    matchingCards.forEach((card, index) => {
      card.hidden = index < startIndex || index >= endIndex;
    });

    filterList?.scrollTo({ left: 0, behavior: "auto" });

    if (filterStatus) {
      const resultLabel = currentFilter.type === "all" ? "all articles" : currentFilter.value;
      const rangeStart = matchingCards.length === 0 ? 0 : startIndex + 1;
      const rangeEnd = Math.min(endIndex, matchingCards.length);
      filterStatus.textContent =
        matchingCards.length === 0
          ? `No articles found for ${resultLabel}.`
          : `Showing ${rangeStart}-${rangeEnd} of ${matchingCards.length} ${resultLabel}.`;
    }

    if (!pagination || !paginationPages || !previousButton || !nextButton) return;

    pagination.hidden = pageCount <= 1;
    previousButton.disabled = currentPage === 1;
    nextButton.disabled = currentPage === pageCount;
    paginationPages.innerHTML = "";

    for (let page = 1; page <= pageCount; page += 1) {
      const button = document.createElement("button");
      button.className = "blog-pagination-page";
      button.type = "button";
      button.textContent = String(page);
      button.setAttribute("aria-label", `Go to page ${page}`);
      button.setAttribute("aria-current", page === currentPage ? "page" : "false");
      button.addEventListener("click", () => {
        currentPage = page;
        updatePagination();
      });
      paginationPages.append(button);
    }
  };

  const setActiveFilter = (activeButton: HTMLButtonElement) => {
    currentFilter = {
      type: activeButton.dataset.blogFilter ?? "all",
      value: activeButton.dataset.blogValue ?? "all",
    };
    currentPage = 1;

    filterButtons?.forEach((button) => {
      button.setAttribute("aria-pressed", String(button === activeButton));
    });

    updatePagination();
  };

  previousButton?.addEventListener("click", () => {
    currentPage = Math.max(1, currentPage - 1);
    updatePagination();
  });

  nextButton?.addEventListener("click", () => {
    currentPage += 1;
    updatePagination();
  });

  filterButtons?.forEach((button) => {
    button.addEventListener("click", () => setActiveFilter(button));
  });

  updatePagination();
</script>
