---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/common/Breadcrumb.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import FeatureCard from "../components/common/FeatureCard.astro";
---

<BaseLayout title="About Us" description="About page placeholder for the Travel Agent Taxi and Tour frontend.">
  <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "About Us" }]} />
  <section class="container-page section-padding">
    <SectionHeader eyebrow="About" title="About the travel service" description="STEP 0 placeholder page prepared for future brand story, local expertise, and trust content." />
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <FeatureCard title="Private taxi" description="Foundation for pick up, drop, airport, ferry, hotel, and custom routes." />
      <FeatureCard title="Island tours" description="Foundation for curated tour package content and future CMS data." />
      <FeatureCard title="WhatsApp-first" description="Simple conversion path before a full booking engine is needed." />
    </div>
  </section>
</BaseLayout>
