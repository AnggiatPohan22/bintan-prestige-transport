---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/common/Breadcrumb.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import AboutHero from "../components/about/AboutHero.astro";
import AboutStory from "../components/about/AboutStory.astro";
import TrustSignals from "../components/about/TrustSignals.astro";
import WhatsAppCTA from "../components/common/WhatsAppCTA.astro";
import { breadcrumbSchema, organizationSchema } from "../data/schema";

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "/about" },
];
const schema = [organizationSchema, breadcrumbSchema(breadcrumbs)];
---

<BaseLayout title="About Us" description="About the premium private taxi, transfer, and island tour concierge service foundation." canonical="/about" schema={schema}>
  <AboutHero />
  <Breadcrumb items={breadcrumbs} />
  <AboutStory />
  <section class="editorial-section-warm">
    <div class="editorial-container">
      <SectionHeader eyebrow="Trust signals" title="A foundation built for practical premium travel" description="These signals keep the story grounded until real reviews, certifications, fleet photos, and business credentials are added." tone="light" variant="editorial" />
      <div class="mt-8">
        <TrustSignals />
      </div>
    </div>
  </section>
  <WhatsAppCTA title="Need private transfer or tour help?" />
</BaseLayout>
