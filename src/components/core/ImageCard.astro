---
interface Props {
  title: string;
  description?: string;
  image: string;
  alt: string;
}

const { title, description, image, alt } = Astro.props;
---

<article class="luxury-card group overflow-hidden rounded-[8px] transition hover:border-[#f8e7a1]/38">
  <div class="visual-placeholder relative aspect-[4/3] overflow-hidden">
    <img
      class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.02]"
      src={image}
      alt={alt}
      loading="lazy"
    />
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(11,12,16,0.16),rgba(6,78,59,0.34))]" aria-hidden="true"></div>
  </div>
  <div class="p-4">
    <h3 class="text-base font-semibold text-[#e2e8f0]">{title}</h3>
    {description && <p class="mt-2 text-sm leading-6 text-slate-400">{description}</p>}
  </div>
</article>
