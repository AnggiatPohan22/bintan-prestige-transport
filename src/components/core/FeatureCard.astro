---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="info-light-card luxury-card rounded-[8px] p-5 transition hover:border-[#f8e7a1]/38">
  <div class="mb-4 h-1.5 w-12 rounded-full bg-[#d6b25e] shadow-[0_0_24px_rgba(214,178,94,0.28)]"></div>
  <h3 class="text-base font-semibold text-[#e2e8f0]">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-slate-400">{description}</p>
</article>
