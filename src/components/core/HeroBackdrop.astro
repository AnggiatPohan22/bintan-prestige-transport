---
import type { HeroImageAsset } from "@data/assets";

interface Props {
  images?: Array<string | HeroImageAsset>;
  video?: string;
  className?: string;
}

const { images = [], video = "", className = "-z-20" } = Astro.props;
const activeImages = images.filter(Boolean);
const duration = Math.max(activeImages.length * 6, 12);
const getImageSrc = (image: string | HeroImageAsset) => (typeof image === "string" ? image : image.src);
---

<div class={`absolute inset-0 ${className}`} aria-hidden="true">
  <div class="absolute inset-0 visual-placeholder"></div>
  {
    activeImages.length > 0 && (
      <div class="hero-slideshow absolute inset-0">
        {activeImages.map((image, index) => (
          <div
            class:list={[
              "hero-slide absolute inset-0",
              activeImages.length === 1 && "hero-slide-static",
            ]}
            style={`animation-delay: ${index * 6}s; animation-duration: ${duration}s;`}
          >
            {
              typeof image === "string" ? (
                <img
                  class="hero-slide__image"
                  src={image}
                  alt=""
                  width="1760"
                  height="990"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
              ) : (
                <picture>
                  <source media="(max-width: 640px)" srcset={image.mobile} />
                  <source media="(max-width: 1024px)" srcset={image.tablet} />
                  <source media="(min-width: 1025px)" srcset={image.desktop} />
                  <img
                    class="hero-slide__image"
                    src={getImageSrc(image)}
                    alt=""
                    width="1760"
                    height="990"
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                    fetchpriority={index === 0 ? "high" : "auto"}
                  />
                </picture>
              )
            }
          </div>
        ))}
      </div>
    )
  }
  {
    video && (
      <video class="absolute inset-0 h-full w-full object-cover opacity-24" autoplay muted loop playsinline preload="metadata">
        <source src={video} type="video/mp4" />
      </video>
    )
  }
</div>
