---
interface Item {
  label: string;
  href?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="container-page pt-6 text-sm text-slate-500">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {item.href ? <a class="hover:text-[#e2e8f0]" href={item.href}>{item.label}</a> : <span class="text-[#e2e8f0]">{item.label}</span>}
        {index < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
