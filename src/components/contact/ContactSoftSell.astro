---
const items = [
  {
    title: "Fast first response",
    description: "Send the prepared message and the team can understand your route, date, and guest needs faster.",
  },
  {
    title: "Route clarity before pickup",
    description: "Clarify pickup point, drop-off plan, waiting time, and activity stops before the driver arrives.",
  },
  {
    title: "Private Bintan support",
    description: "Plan ferry transfers, airport pickup, resort movement, city visits, beach routes, and activity packages with one contact path.",
  },
];
---

<section class="editorial-section-dark border-t border-[#bfa46f]/12">
  <div class="editorial-container grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
    <div>
      <p class="editorial-kicker">Before you send</p>
      <h2 class="mt-3 font-[var(--font-editorial-heading)] text-3xl font-medium leading-tight text-[#f8fafc] sm:text-4xl">
        A better message helps us prepare a better route.
      </h2>
      <p class="mt-4 text-sm leading-7 text-slate-400">
        The more complete your first message is, the easier it is for Bintan Prestige to suggest the right vehicle, schedule, route flow, and package option.
      </p>
    </div>

    <div class="grid gap-3">
      {items.map((item) => (
        <article class="rounded-[8px] border border-[#bfa46f]/18 bg-[#071a14]/54 p-5">
          <h3 class="font-[var(--font-editorial-heading)] text-2xl font-medium leading-tight text-[#f8fafc]">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-400">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
