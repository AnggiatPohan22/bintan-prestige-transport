---
import { Clock, Mail, MapPin, Phone } from "lucide-react";
import { site } from "../../data/site";

const cards = [
  { title: "WhatsApp / Phone", value: site.phone, icon: Phone },
  { title: "Email", value: site.email, icon: Mail },
  { title: "Service Area", value: site.address, icon: MapPin },
  { title: "Response Window", value: site.responseWindow, icon: Clock },
];
---

<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
  {cards.map((card) => {
    const Icon = card.icon;
    return (
      <article class="editorial-card rounded-[8px] p-5 transition duration-300 hover:-translate-y-0.5 hover:border-[#f8e7a1]/34">
        <span class="flex h-10 w-10 items-center justify-center rounded-[8px] border border-[#bfa46f]/28 bg-[#bfa46f]/10 text-[#f8e7a1]">
          <Icon className="h-5 w-5" aria-hidden="true" />
        </span>
        <p class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-[#f8e7a1]/72">{card.title}</p>
        <p class="mt-2 text-sm leading-6 text-slate-400">{card.value}</p>
      </article>
    );
  })}
</div>
