---
import { site } from "../../data/site";

const message =
  "Hello, I want to plan a premium taxi or island tour. Pickup: -, Drop-off: -, Date/time: -, Passengers: -, Luggage: -, Service type: -.";
const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(message)}`;

const fields = ["Pickup", "Drop-off", "Date and time", "Passengers", "Luggage", "Service type"];
---

<div class="luxury-surface silver-glow rounded-[8px] p-5 sm:p-6">
  <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[#e2e8f0]/60">Message template</p>
      <h2 class="mt-3 text-2xl font-semibold text-[#e2e8f0] sm:text-3xl">Prepare the details before opening WhatsApp.</h2>
      <p class="mt-3 text-sm leading-6 text-slate-400">
        This is still not a backend form. It is a lightweight planning panel that sends visitors to WhatsApp with a clear starting message.
      </p>
    </div>
    <div>
      <div class="grid gap-3 sm:grid-cols-2">
        {fields.map((field) => (
          <div class="rounded-[8px] border border-white/10 bg-white/[0.03] p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">{field}</p>
            <p class="mt-1 text-sm text-[#e2e8f0]">Add in WhatsApp</p>
          </div>
        ))}
      </div>
      <a class="mt-5 inline-flex min-h-12 w-full items-center justify-center rounded-full bg-[#e2e8f0] px-6 text-sm font-semibold text-[#0b0c10] transition hover:bg-white sm:w-auto" href={href} target="_blank" rel="noreferrer">
        Open WhatsApp Planner
      </a>
    </div>
  </div>
</div>
