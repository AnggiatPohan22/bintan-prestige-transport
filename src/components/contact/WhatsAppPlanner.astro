---
import { site } from "../../data/site";

const message =
  "Hello, I want to plan a premium taxi or island tour. Pickup: -, Drop-off: -, Date/time: -, Passengers: -, Luggage: -, Service type: -.";
const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(message)}`;

const fields = ["Pickup", "Drop-off", "Date and time", "Passengers", "Luggage", "Service type"];
---

<div class="luxury-surface silver-glow rounded-[8px] p-5 sm:p-6">
  <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div>
      <p class="editorial-kicker">Message template</p>
      <h2 class="mt-3 font-[var(--font-editorial-heading)] text-3xl font-medium leading-tight text-[#f8fafc] sm:text-4xl">Prepare the details before opening WhatsApp.</h2>
      <p class="mt-3 text-sm leading-6 text-slate-400">
        This is still not a backend form. It is a lightweight planning panel that sends visitors to WhatsApp with a clear starting message.
      </p>
    </div>
    <div>
      <div class="grid gap-3 sm:grid-cols-2">
        {fields.map((field) => (
          <div class="rounded-[8px] border border-[#bfa46f]/20 bg-[#071a14]/46 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#bfa46f]">{field}</p>
            <p class="mt-1 text-sm text-[#f8fafc]">Add in WhatsApp</p>
          </div>
        ))}
      </div>
      <a class="editorial-button-primary mt-5 min-h-12 w-full px-6 sm:w-auto" href={href} target="_blank" rel="noreferrer">
        Open WhatsApp Planner
      </a>
    </div>
  </div>
</div>
