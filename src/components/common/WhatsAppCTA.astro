---
import { site } from "../../data/site";

interface Props {
  title?: string;
  description?: string;
  message?: string;
}

const {
  title = "Ready to plan your taxi or tour?",
  description = "Start with WhatsApp and share your route, date, guest count, and preferred schedule.",
  message = site.whatsappMessage,
} = Astro.props;

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(message)}`;
const ctaImage = "/images/tours/jetski 4.jpg";
---

<section class="container-page section-padding">
  <div class="cta-soft-sell luxury-surface overflow-hidden rounded-[8px] text-white md:grid md:grid-cols-[1.05fr_0.95fr]">
    <div class="p-6 sm:p-8 lg:p-10">
      <p class="editorial-kicker">Private concierge</p>
      <h2 class="mt-3 font-[var(--font-editorial-heading)] text-3xl font-medium leading-tight text-[#f8fafc] sm:text-4xl">{title}</h2>
      <p class="mt-4 text-sm leading-7 text-slate-400 sm:text-base">{description}</p>
      <div class="mt-6 grid gap-3 text-sm text-[#f8e7a1] sm:grid-cols-3">
        <span class="rounded-[8px] border border-[#bfa46f]/24 bg-[#064e3b]/24 p-3">Private driver</span>
        <span class="rounded-[8px] border border-[#bfa46f]/24 bg-[#064e3b]/24 p-3">Custom route</span>
        <span class="rounded-[8px] border border-[#bfa46f]/24 bg-[#064e3b]/24 p-3">Fast WhatsApp</span>
      </div>
      <a
        class="luxury-btn-primary mt-7 min-h-12 px-5"
        href={href}
        target="_blank"
        rel="noreferrer"
        aria-label="Chat on WhatsApp"
      >
        Chat on WhatsApp
      </a>
    </div>
    <div
      class="min-h-72 bg-cover bg-center md:min-h-full"
      role="img"
      aria-label="Premium Bintan tour and taxi planning"
      style={`background-image: linear-gradient(90deg, rgba(11,12,16,0.12), rgba(11,12,16,0.74)), url('${ctaImage}');`}
    >
      <div class="flex h-full items-end p-5">
        <div class="rounded-[8px] border border-[#f8e7a1]/22 bg-black/36 p-4 backdrop-blur">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#f8e7a1]">Soft selling route</p>
          <p class="mt-2 max-w-xs text-sm leading-6 text-white/82">From airport transfer to island moments, one WhatsApp chat can shape the whole day.</p>
        </div>
      </div>
    </div>
  </div>
</section>
