---
import { site } from "../../data/site";

interface Props {
  title?: string;
  description?: string;
  message?: string;
}

const {
  title = "Ready to plan your taxi or tour?",
  description = "Start with WhatsApp and share your route, date, guest count, and preferred schedule.",
  message = site.whatsappMessage,
} = Astro.props;

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(message)}`;
---

<section class="container-page section-padding">
  <div class="luxury-surface silver-glow rounded-[8px] p-6 text-white sm:p-8 md:flex md:items-center md:justify-between md:gap-8">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold text-[#e2e8f0] sm:text-3xl">{title}</h2>
      <p class="mt-3 text-sm leading-6 text-slate-400 sm:text-base">{description}</p>
    </div>
    <div class="mt-6 md:mt-0">
      <a
        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[#e2e8f0] px-5 text-sm font-semibold text-[#0b0c10] shadow-[0_0_28px_rgba(226,232,240,0.16)] transition-colors hover:bg-white focus:outline-none focus:ring-2 focus:ring-[#e2e8f0]/60 focus:ring-offset-2 focus:ring-offset-[#0b0c10]"
        href={href}
        target="_blank"
        rel="noreferrer"
        aria-label="Chat on WhatsApp"
      >
        Chat on WhatsApp
      </a>
    </div>
  </div>
</section>
