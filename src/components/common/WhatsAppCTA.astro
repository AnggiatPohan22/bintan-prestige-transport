---
import MotionButton from "../animations/MotionButton";
import { site } from "../../data/site";

interface Props {
  title?: string;
  description?: string;
  message?: string;
}

const {
  title = "Ready to plan your taxi or tour?",
  description = "Start with WhatsApp and share your route, date, guest count, and preferred schedule.",
  message = site.whatsappMessage,
} = Astro.props;

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(message)}`;
---

<section class="container-page section-padding">
  <div class="rounded-[8px] bg-[#111317] p-6 text-white shadow-xl sm:p-8 md:flex md:items-center md:justify-between md:gap-8">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold sm:text-3xl">{title}</h2>
      <p class="mt-3 text-sm leading-6 text-white/70 sm:text-base">{description}</p>
    </div>
    <div class="mt-6 md:mt-0">
      <MotionButton client:load href={href} label="Chat on WhatsApp" />
    </div>
  </div>
</section>
