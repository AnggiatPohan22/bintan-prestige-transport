---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";

const footerLogo = site.logoImage || "/images/brand/bintan-prestige-white-logo.png";
---

<footer class="border-t border-[#bfa46f]/16 bg-[#08090d] text-white">
  <div class="editorial-container grid gap-10 py-12 md:grid-cols-[1.25fr_0.7fr_0.9fr_1fr] lg:py-16">
    <div class="max-w-xl">
      <img class="h-16 w-auto max-w-56 object-contain" src={footerLogo} alt={`${site.shortName} logo`} loading="lazy" />
      <p class="editorial-kicker mt-5">Private Travel Concierge</p>
      <p class="mt-3 text-sm font-semibold uppercase tracking-[0.14em] text-[#f8e7a1]">{site.tagline}</p>
      <p class="editorial-copy mt-5 text-slate-400">{site.defaultDescription}</p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#bfa46f]">Explore</p>
      <div class="mt-4 grid gap-2 text-sm text-slate-400">
        {navigation.map((item) => <a class="transition hover:text-[#f8e7a1]" href={item.href}>{item.label}</a>)}
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#bfa46f]">Contact</p>
      <div class="mt-4 grid gap-2 text-sm leading-6 text-slate-400">
        <a class="transition hover:text-[#f8e7a1]" href={`tel:${site.phone}`}>{site.phone}</a>
        <a class="transition hover:text-[#f8e7a1]" href={`mailto:${site.email}`}>{site.email}</a>
        <span>{site.address}</span>
        <span>{site.responseWindow}</span>
      </div>
    </div>

    <div class="trusted-frame rounded-[8px] border border-[#bfa46f]/20 bg-[#071a14]/72 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#bfa46f]">Trusted Website</p>
      <div class="mt-4 grid gap-3 text-sm leading-6 text-slate-300">
        <span class="flex items-start gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#f8e7a1]"></span> WhatsApp-first booking confirmation</span>
        <span class="flex items-start gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#f8e7a1]"></span> Transparent route and package details</span>
        <span class="flex items-start gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#f8e7a1]"></span> Static, fast, and mobile-friendly website</span>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 py-5">
    <div class="editorial-container flex flex-col gap-2 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>Copyright {new Date().getFullYear()} {site.shortName}. All rights reserved.</p>
      <p>Premium taxi, transfer, and private tour experience.</p>
    </div>
  </div>
</footer>
