---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";

const footerLogo = site.logoImage || "/images/brand/bintan-prestige-white-logo.png";
const whatsappHref = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
const trustItems = [
  "Private driver coordination",
  "Taxi, tour, and activity support",
  "Clear WhatsApp confirmation",
];

const policyLinks = [
  { href: "/privacy", label: "Privacy" },
  { href: "/terms", label: "Terms" },
  { href: "/cancellation", label: "Cancellation" },
  { href: "/refund", label: "Refund" },
];
---

<footer class="site-footer">
  <div class="site-footer__glow" aria-hidden="true"></div>
  <div class="site-footer__inner editorial-container">
    <div class="site-footer__brand">
      <img class="site-footer__logo" src={footerLogo} alt={`${site.shortName} logo`} loading="lazy" />
      <p class="site-footer__copy">{site.defaultDescription}</p>
      <div class="site-footer__cta-row">
        <a class="site-footer__primary" href={whatsappHref} target="_blank" rel="noreferrer">Chat on WhatsApp</a>
        <a class="site-footer__secondary" href="/contact">Plan a route</a>
      </div>
    </div>

    <div class="site-footer__column">
      <p class="site-footer__heading">Explore</p>
      <div class="site-footer__links">
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </div>

    <div class="site-footer__column">
      <p class="site-footer__heading">Contact</p>
      <div class="site-footer__links site-footer__links--contact">
        <a href={`tel:${site.phone}`}>{site.phone}</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span>{site.address}</span>
        <span>{site.responseWindow}</span>
      </div>
    </div>

    <div class="site-footer__promise">
      <p class="site-footer__heading">Bintan Prestige</p>
      <div class="site-footer__promise-list">
        {trustItems.map((item) => (
          <span>
            <i aria-hidden="true"></i>
            {item}
          </span>
        ))}
      </div>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="editorial-container">
      <p>Copyright {new Date().getFullYear()} {site.shortName}. All rights reserved.</p>
      <nav class="site-footer__legal" aria-label="Policy links">
        {policyLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
      <p>
        Design & Maintenance by{" "}
        <a href="https://www.giatteh.com" target="_blank" rel="noreferrer">
          Giattech
        </a>
      </p>
    </div>
  </div>
</footer>
