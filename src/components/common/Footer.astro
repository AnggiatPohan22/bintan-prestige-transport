---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";
---

<footer class="border-t border-white/10 bg-[#0b0c10] text-white">
  <div class="container-page grid gap-8 py-10 md:grid-cols-[1.4fr_1fr_1fr]">
    <div class="max-w-md">
      <p class="text-lg font-semibold text-[#e2e8f0]">{site.name}</p>
      <p class="mt-3 text-sm leading-6 text-slate-400">{site.defaultDescription}</p>
    </div>

    <div>
      <p class="text-sm font-semibold text-[#e2e8f0]">Menu</p>
      <div class="mt-3 grid gap-2 text-sm text-slate-400">
        {navigation.map((item) => <a class="hover:text-[#e2e8f0]" href={item.href}>{item.label}</a>)}
      </div>
    </div>

    <div>
      <p class="text-sm font-semibold text-[#e2e8f0]">Contact</p>
      <div class="mt-3 grid gap-2 text-sm text-slate-400">
        <span>{site.phone}</span>
        <span>{site.email}</span>
        <span>{site.address}</span>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 py-4">
    <p class="container-page text-xs text-slate-500">Copyright {new Date().getFullYear()} {site.shortName}. All rights reserved.</p>
  </div>
</footer>
