---
import ImageCard from "./ImageCard.astro";

interface GalleryItem {
  title: string;
  description?: string;
  image: string;
  alt: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
  {items.map((item) => <ImageCard {...item} />)}
</div>
