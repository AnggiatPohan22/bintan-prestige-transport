---
interface Props {
  title: string;
  description?: string;
  image: string;
  alt: string;
}

const { title, description, image, alt } = Astro.props;
---

<article class="overflow-hidden rounded-[8px] border border-slate-200 bg-white shadow-sm">
  <div class="aspect-[4/3] bg-slate-100">
    <img class="h-full w-full object-cover" src={image} alt={alt} loading="lazy" />
  </div>
  <div class="p-4">
    <h3 class="text-base font-semibold text-[#111317]">{title}</h3>
    {description && <p class="mt-2 text-sm leading-6 text-slate-600">{description}</p>}
  </div>
</article>
