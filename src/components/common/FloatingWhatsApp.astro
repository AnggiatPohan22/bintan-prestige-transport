---
import { MessageCircle } from "lucide-react";
import { site } from "../../data/site";

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<a
  class="luxury-btn-primary fixed bottom-4 right-4 z-40 min-h-12 px-4 focus:outline-none focus:ring-2 focus:ring-[#f8e7a1]/70 focus:ring-offset-2 focus:ring-offset-[#0b0c10]"
  href={href}
  target="_blank"
  rel="noreferrer"
  aria-label="Chat on WhatsApp"
>
  <MessageCircle className="h-4 w-4" aria-hidden="true" />
  <span class="hidden sm:inline">WhatsApp</span>
</a>
