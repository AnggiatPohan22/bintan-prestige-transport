---
import { MessageCircle } from "lucide-react";
import { site } from "../../data/site";

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<a
  class="fixed bottom-4 right-4 z-40 inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-[#e2e8f0]/20 bg-[#e2e8f0] px-4 text-sm font-semibold text-[#0b0c10] shadow-[0_18px_55px_rgba(0,0,0,0.28)] transition hover:bg-white focus:outline-none focus:ring-2 focus:ring-[#e2e8f0]/60 focus:ring-offset-2 focus:ring-offset-[#0b0c10]"
  href={href}
  target="_blank"
  rel="noreferrer"
  aria-label="Chat on WhatsApp"
>
  <MessageCircle className="h-4 w-4" aria-hidden="true" />
  <span class="hidden sm:inline">WhatsApp</span>
</a>
