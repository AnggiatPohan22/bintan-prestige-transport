---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const alignClass = align === "center" ? "mx-auto text-center" : "";
---

<div class={`max-w-2xl ${alignClass}`}>
  {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#c9a14a]">{eyebrow}</p>}
  <h2 class="mt-2 text-2xl font-semibold text-[#111317] sm:text-3xl">{title}</h2>
  {description && <p class="mt-3 text-base leading-7 text-slate-600">{description}</p>}
</div>
