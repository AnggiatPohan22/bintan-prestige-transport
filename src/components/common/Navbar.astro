---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";
import MobileNav from "./MobileNav.astro";
---

<header class="sticky top-0 z-[80] border-b border-[#bfa46f]/18 bg-[#0b0c10]/88 text-white shadow-[0_18px_50px_rgba(0,0,0,0.18)] backdrop-blur-xl">
  <nav class="editorial-container flex min-h-[4.5rem] items-center justify-between gap-4 py-3">
    <a href="/" class="group flex min-w-0 items-center gap-3" aria-label={`${site.shortName} home`}>
      {
        site.logoImage ? (
          <img class="h-11 w-auto max-w-[154px] object-contain transition duration-200 group-hover:opacity-90 sm:max-w-[210px]" src={site.logoImage} alt={`${site.shortName} logo`} />
        ) : (
          <span class="flex min-w-0 flex-col">
            <span class="font-[var(--font-editorial-heading)] text-xl font-medium leading-none tracking-wide text-[#f8fafc]">{site.shortName}</span>
            <span class="mt-1 hidden text-[11px] font-semibold uppercase tracking-[0.18em] text-[#bfa46f] sm:block">{site.tagline}</span>
          </span>
        )
      }
    </a>

    <div class="hidden items-center gap-7 text-[13px] font-semibold uppercase tracking-[0.13em] text-slate-300 md:flex">
      {navigation.map((item) => <a class="transition hover:text-[#f8e7a1]" href={item.href}>{item.label}</a>)}
    </div>

    <div class="flex items-center gap-2">
      <a
        class="editorial-button-primary hidden min-h-11 px-5 sm:inline-flex"
        href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`}
        target="_blank"
        rel="noreferrer"
      >
        WhatsApp
      </a>
      <MobileNav />
    </div>
  </nav>
</header>
