---
import { CalendarCheck, Send, X } from "lucide-react";
import PackageBookingFields from "./PackageBookingFields.astro";
import { site } from "@data/site";

interface DetailItem {
  title: string;
  slug?: string;
  priceFrom?: string;
  duration?: string;
  whatsappMessage?: string;
}

interface Props {
  item: DetailItem;
  typeLabel: string;
  tone?: "default" | "light";
  collapsedPreview?: boolean;
}

const { item, typeLabel, tone = "default", collapsedPreview = false } = Astro.props;
const defaultMessage = item.whatsappMessage ?? `Hello, I want to book ${item.title}.`;
const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(defaultMessage)}`;
const bookingPanelId = `package-booking-form-${item.slug ?? item.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
---

<section
  class:list={[
    "package-booking-section editorial-section-dark border-y border-[#bfa46f]/12",
    tone === "light" && "package-booking-section--light",
    collapsedPreview && "package-booking-section--collapsible",
  ]}
  data-booking-collapsible={collapsedPreview ? "true" : undefined}
  data-booking-expanded={collapsedPreview ? "false" : undefined}
>
  <div class="editorial-container grid gap-8 lg:grid-cols-[0.86fr_1.14fr] lg:items-start lg:gap-10">
    <div class="package-booking-copy">
      <p class="editorial-kicker">Booking Information</p>
      <h2 class="editorial-title mt-3 text-[#f8fafc]">Customize your request before WhatsApp.</h2>
      <p class="editorial-lede mt-4 text-slate-400">
        Add date, time, pickup point, guest count, and special notes. The button will generate a ready-to-send WhatsApp message for this package.
      </p>
      <div class="package-booking-summary mt-7">
        <span class="package-booking-summary__eyebrow">{typeLabel}</span>
        <strong>{item.title}</strong>
        <div class="package-booking-summary__meta">
          {item.priceFrom && <span>From {item.priceFrom}</span>}
          {item.duration && <span>Duration: {item.duration}</span>}
        </div>
      </div>
    </div>

    <div class="package-booking-form-stack">
      {collapsedPreview && (
        <div class="package-booking-reveal" data-booking-reveal-card>
          <span class="package-booking-reveal__icon"><CalendarCheck className="h-5 w-5" aria-hidden="true" /></span>
          <div class="package-booking-reveal__copy">
            <span>Quick booking form</span>
            <strong>Fill form here to book</strong>
            <p>Add your date, pickup point, guest count, and notes before the WhatsApp message is prepared.</p>
          </div>
          <button
            class="package-booking-reveal__button editorial-button-primary"
            type="button"
            aria-controls={bookingPanelId}
            aria-expanded="false"
            data-booking-reveal
          >
            <CalendarCheck className="h-4 w-4" aria-hidden="true" />
            <span>Fill Form here to book</span>
          </button>
        </div>
      )}

      <form
        id={bookingPanelId}
        class="package-booking-form editorial-card p-4 sm:p-6 lg:p-7"
        action={href}
        data-package-booking
        data-whatsapp-number={site.whatsappNumber}
        data-package-title={item.title}
        data-package-type={typeLabel}
        data-package-price={item.priceFrom ?? "To be confirmed"}
        data-package-duration={item.duration ?? "To be confirmed"}
        data-booking-panel={collapsedPreview ? "true" : undefined}
        hidden={collapsedPreview ? true : undefined}
      >
        <PackageBookingFields />

        <a class="package-booking-cta editorial-button-primary mt-5 w-full px-4" href={href} target="_blank" rel="noreferrer" data-booking-link>
          <Send className="h-4 w-4" aria-hidden="true" />
          <span>Book via WhatsApp</span>
        </a>

        {collapsedPreview && (
          <button class="package-booking-close" type="button" data-booking-close>
            <X className="h-4 w-4" aria-hidden="true" />
            <span>Hide booking form</span>
          </button>
        )}
      </form>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>("[data-package-booking]").forEach((form) => {
    const link = form.querySelector<HTMLAnchorElement>("[data-booking-link]");

    const buildUrl = () => {
      const data = new FormData(form);
      const phone = form.dataset.whatsappNumber ?? "";
      const title = form.dataset.packageTitle ?? "Package";
      const type = form.dataset.packageType ?? "Package";
      const price = form.dataset.packagePrice ?? "To be confirmed";
      const duration = form.dataset.packageDuration ?? "To be confirmed";
      const date = data.get("date")?.toString() || "Flexible / to confirm";
      const time = data.get("time")?.toString() || "Flexible / to confirm";
      const guests = data.get("guests")?.toString() || "To be confirmed";
      const pickup = data.get("pickup")?.toString() || "To be confirmed";
      const dropoff = data.get("dropoff")?.toString() || "To be confirmed";
      const notes = data.get("notes")?.toString() || "-";
      const message = [
        `Hello, I want to book ${title}.`,
        "",
        `Package type: ${type}`,
        `Price from: ${price}`,
        `Duration: ${duration}`,
        `Travel date: ${date}`,
        `Preferred time: ${time}`,
        `Guests: ${guests}`,
        `Pickup point: ${pickup}`,
        `Drop-off / return: ${dropoff}`,
        `Custom request: ${notes}`,
        "",
        "Please confirm availability, final price, and recommended itinerary.",
      ].join("\n");

      return `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
    };

    const updateLink = () => {
      if (link) {
        link.href = buildUrl();
      }
    };

    form.addEventListener("input", updateLink);
    form.addEventListener("change", updateLink);
    updateLink();
  });

  document.querySelectorAll<HTMLElement>("[data-booking-collapsible]").forEach((section) => {
    const reveal = section.querySelector<HTMLButtonElement>("[data-booking-reveal]");
    const close = section.querySelector<HTMLButtonElement>("[data-booking-close]");
    const revealCard = section.querySelector<HTMLElement>("[data-booking-reveal-card]");
    const panel = section.querySelector<HTMLElement>("[data-booking-panel]");

    reveal?.addEventListener("click", () => {
      if (!panel) return;

      panel.hidden = false;
      section.dataset.bookingExpanded = "true";
      reveal.setAttribute("aria-expanded", "true");
      revealCard?.setAttribute("hidden", "");

      requestAnimationFrame(() => {
        panel.scrollIntoView({ block: "center", behavior: "smooth" });
        const firstField = panel.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>("input, select, textarea");
        firstField?.focus({ preventScroll: true });
      });
    });

    close?.addEventListener("click", () => {
      if (!panel) return;

      panel.hidden = true;
      section.dataset.bookingExpanded = "false";
      reveal?.setAttribute("aria-expanded", "false");
      revealCard?.removeAttribute("hidden");

      requestAnimationFrame(() => {
        revealCard?.scrollIntoView({ block: "center", behavior: "smooth" });
        reveal?.focus({ preventScroll: true });
      });
    });
  });
</script>
