---
import SwipeControls from "@components/core/SwipeControls.astro";
import { site } from "@data/site";

interface RouteItem {
  title: string;
  slug: string;
  description: string;
  image?: string;
  alt?: string;
  duration?: string;
  capacity?: string;
  category?: string;
  priceFrom?: string;
  highlights?: string[];
  whatsappMessage?: string;
}

interface Props {
  items: RouteItem[];
}

const { items } = Astro.props;

const getPriceDisplay = (value?: string) => {
  if (!value) {
    return null;
  }

  if (/^Depending Requests$/i.test(value)) {
    return {
      label: "Rate",
      price: "By Request",
    };
  }

  const capacityMatch = value.match(/^Capacity\s*:\s*(.+)$/i);

  if (capacityMatch) {
    return {
      label: "Capacity",
      price: capacityMatch[1],
    };
  }

  const startFromMatch = value.match(/^Start From\s*:\s*(.+)$/i);

  if (startFromMatch) {
    return {
      label: "Start From",
      price: startFromMatch[1],
    };
  }

  return {
    label: "Rate",
    price: value,
  };
};
---

<div class="transfer-route-carousel" data-swipe-carousel>
  <div class="package-card-grid" data-swipe-track>
    {items.map((item) => {
      const priceDisplay = getPriceDisplay(item.priceFrom);

      return (
        <article class={`package-offer-card package-offer-card--${item.category ?? "route"} group`} data-swipe-item>
          {item.image && (
            <div class="package-offer-card__media">
              <img
                class="package-offer-card__image"
                src={item.image}
                alt={item.alt ?? item.title}
                loading="lazy"
              />
              <div class="package-offer-card__shade" aria-hidden="true"></div>
              <div class="package-offer-card__badges">
                {item.category && <span class="package-offer-card__category">{item.category}</span>}
                {priceDisplay && (
                  <span class="package-offer-card__price">
                    <span>{priceDisplay.label}</span>
                    <strong>{priceDisplay.price}</strong>
                  </span>
                )}
              </div>
            </div>
          )}
          <div class="package-offer-card__body">
            <div class="package-offer-card__copy">
              <h3 class="package-offer-card__title">{item.title}</h3>
              <p class="package-offer-card__description">{item.description}</p>
            </div>
            <div class="package-offer-card__meta" aria-label="Package basics">
              {item.duration && <span>{item.duration}</span>}
              {item.capacity && <span>{item.capacity}</span>}
            </div>
            <ul class="package-offer-card__highlights" aria-label="Package highlights">
              {(item.highlights ?? []).slice(0, 3).map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
            <div class="package-offer-card__actions">
              <a class="package-offer-card__link package-offer-card__link--secondary" href={`/packages/pick-up-drop/${item.slug}`}>
                Read more
              </a>
              <a
                class="package-offer-card__link package-offer-card__link--primary"
                href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(item.whatsappMessage ?? `Hello, I want to ask about ${item.title}.`)}`}
                target="_blank"
                rel="noreferrer"
              >
                Ask availability
              </a>
            </div>
          </div>
        </article>
      );
    })}
  </div>
  <SwipeControls count={items.length} label="Transfer packages" className="transfer-swipe-dots" />
</div>
