---
import ActivityPackageGallery from "@components/features/packages/ActivityPackageGallery.astro";
import SwipeControls from "@components/core/SwipeControls.astro";

interface GalleryItem {
  title: string;
  description?: string;
  image: string;
  alt: string;
}

interface DetailItem {
  title: string;
  gallery?: GalleryItem[];
  highlights?: string[];
  itinerary?: string[];
  includes?: string[];
  excludes?: string[];
  bookingNotes?: string[];
  goodFor?: string[];
  whyChoose?: string[];
  terms?: string[];
  packageDetails?: {
    title: string;
    value?: string;
    description: string;
  }[];
}

interface Props {
  item: DetailItem;
  enableMobileSwipeControls?: boolean;
  tone?: "default" | "activities";
}

const { item, enableMobileSwipeControls = false, tone = "default" } = Astro.props;
const detailCards: NonNullable<DetailItem["packageDetails"]> = item.packageDetails ?? item.highlights?.map((highlight) => ({
  title: "Package highlight",
  description: highlight,
})) ?? [];
const showMobileSwipeControls = enableMobileSwipeControls && detailCards.length > 1;
const isActivitiesTone = tone === "activities";
const showActivityInfoSwipe = Boolean(item.includes?.length || item.bookingNotes?.length);
const activitySupportPanelCount = Number(Boolean(item.whyChoose?.length)) + Number(Boolean(item.terms?.length));
const showActivitySupportSwipe = isActivitiesTone && activitySupportPanelCount > 1;
---

<section class="editorial-section-dark">
  <div class="editorial-container">
    <div class="max-w-3xl">
      <p class="editorial-kicker">Package Detail</p>
      <h2 class="editorial-title mt-3 text-[#f8fafc]">Clear options before you confirm.</h2>
      <p class="mt-4 text-sm leading-7 text-slate-400">
        Choose the route style that fits your plan, then confirm timing, pickup point, and final availability through WhatsApp.
      </p>
      <div class="mt-6 flex flex-wrap gap-2">
        {item.goodFor?.map((label) => (
          <span class="rounded-full border border-[#bfa46f]/24 bg-[#bfa46f]/10 px-3 py-2 text-xs font-bold text-[#f8e7a1]">{label}</span>
        ))}
      </div>
    </div>

    <div data-swipe-carousel={showMobileSwipeControls ? "package-detail" : undefined}>
      <div class="package-detail-card-row mt-8" data-swipe-track={showMobileSwipeControls ? "true" : undefined}>
        {detailCards.map((detail) => (
          <article class="package-detail-card" data-swipe-item={showMobileSwipeControls ? "true" : undefined}>
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#f8e7a1]/68">{detail.title}</p>
            {detail.value && <h3 class="mt-3 text-2xl font-extrabold leading-tight text-[#f8fafc]">{detail.value}</h3>}
            <p class="mt-4 text-sm leading-7 text-slate-300">{detail.description}</p>
          </article>
        ))}
      </div>

      {showMobileSwipeControls && <SwipeControls count={detailCards.length} label="Package detail slider controls" breakpoint="mobile" className="mt-3" />}
    </div>
  </div>
</section>

{isActivitiesTone && item.gallery?.length ? <ActivityPackageGallery items={item.gallery} /> : null}

<section class="editorial-section-dark border-t border-[#bfa46f]/12">
  <div class="editorial-container grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
    <div class="max-w-2xl">
      <p class="editorial-kicker">Itinerary</p>
      <h2 class="editorial-title mt-3 text-[#f8fafc]">A private flow that stays flexible.</h2>
      <p class="mt-4 text-sm leading-7 text-slate-400">
        The sequence stays simple, so the driver and guest can keep the route calm while still adjusting to timing, luggage, and final stops.
      </p>
    </div>

    <ol class="grid gap-4">
      {item.itinerary?.map((step, index) => (
        <li class="grid grid-cols-[auto_1fr] gap-4 rounded-[8px] border border-white/10 bg-black/18 p-4">
          <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[#bfa46f]/38 bg-[#bfa46f]/12 text-xs font-bold text-[#f8e7a1]">
            {String(index + 1).padStart(2, "0")}
          </span>
          <p class="pt-1 text-sm leading-6 text-slate-300">{step}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<section class="editorial-section-warm">
  <div
    class:list={["editorial-container", showActivityInfoSwipe && "activity-detail-info-carousel"]}
    data-swipe-carousel={showActivityInfoSwipe ? "activity-info" : undefined}
  >
    <div class="activity-detail-info-track" data-swipe-track={showActivityInfoSwipe ? "true" : undefined}>
      <div class:list={["editorial-card editorial-card-warm p-5 sm:p-7", showActivityInfoSwipe && "activity-detail-info-card"]} data-swipe-item={showActivityInfoSwipe ? "true" : undefined}>
        <p class="editorial-kicker">Included Support</p>
        <h2 class="editorial-title mt-3">What we help arrange.</h2>
        <div class:list={["mt-6 grid gap-3 sm:grid-cols-2", showActivityInfoSwipe && "activity-detail-info-list activity-detail-info-list--includes"]}>
          {item.includes?.map((include) => (
            <div class:list={["rounded-[8px] border border-[#e5e0d6] bg-white/70 p-4", showActivityInfoSwipe && "activity-detail-info-item"]}>
              <p class="text-sm font-semibold leading-6 text-[#111827]">{include}</p>
            </div>
          ))}
        </div>
        {item.excludes?.length ? (
          <div class="activity-detail-excludes mt-7">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#8a6a22]">Package Excludes</p>
            <ul class:list={["mt-4 grid gap-3", showActivityInfoSwipe && "activity-detail-info-list activity-detail-info-list--single"]}>
              {item.excludes.map((exclude) => (
                <li class:list={["rounded-[8px] border border-[#e5e0d6] bg-white/70 p-4 text-sm font-semibold leading-6 text-[#4b5563]", showActivityInfoSwipe && "activity-detail-info-item"]}>{exclude}</li>
              ))}
            </ul>
          </div>
        ) : null}
      </div>

      <div class:list={["editorial-card editorial-card-warm p-5 sm:p-7", showActivityInfoSwipe && "activity-detail-info-card"]} data-swipe-item={showActivityInfoSwipe ? "true" : undefined}>
        <p class="editorial-kicker">Booking Notes</p>
        <h2 class="editorial-title mt-3">Confirm before you go.</h2>
        <ul class:list={["mt-6 grid gap-3", showActivityInfoSwipe && "activity-detail-info-list activity-detail-info-list--single"]}>
          {item.bookingNotes?.map((note) => (
            <li class:list={["rounded-[8px] border border-[#e5e0d6] bg-white/70 p-4 text-sm leading-6 text-[#4b5563]", showActivityInfoSwipe && "activity-detail-info-item"]}>{note}</li>
          ))}
        </ul>
      </div>
    </div>

    {showActivityInfoSwipe && <SwipeControls count={2} label="Included support and booking notes slider controls" breakpoint="mobile" className="activity-detail-info-controls mt-4" />}
  </div>
</section>

{(item.whyChoose?.length || item.terms?.length) && (
  <section class:list={["editorial-section-warm border-t border-[#d8c6a3]/40", isActivitiesTone && "activity-detail-support-section"]}>
    <div
      class:list={["editorial-container", showActivitySupportSwipe && "activity-detail-support-carousel"]}
      data-swipe-carousel={showActivitySupportSwipe ? "activity-support" : undefined}
    >
      <div class="activity-detail-support-track grid gap-6 lg:grid-cols-2" data-swipe-track={showActivitySupportSwipe ? "true" : undefined}>
        {item.whyChoose?.length && (
          <div class:list={["editorial-card editorial-card-warm p-5 sm:p-7", isActivitiesTone && "activity-detail-support-card"]} data-swipe-item={showActivitySupportSwipe ? "true" : undefined}>
            <p class="editorial-kicker">Why Choose Bintan Prestige Transport?</p>
            <h2 class="editorial-title mt-3">Private service with reliable support.</h2>
            <ul class:list={["mt-6 grid gap-3 sm:grid-cols-2", showActivitySupportSwipe && "activity-detail-support-list"]}>
              {item.whyChoose.map((reason) => (
                <li class:list={["rounded-[8px] border border-[#e5e0d6] bg-white/70 p-4 text-sm font-semibold leading-6 text-[#111827]", isActivitiesTone && "activity-detail-support-item"]}>{reason}</li>
              ))}
            </ul>
          </div>
        )}

        {item.terms?.length && (
          <div class:list={["editorial-card editorial-card-warm p-5 sm:p-7", isActivitiesTone && "activity-detail-support-card"]} data-swipe-item={showActivitySupportSwipe ? "true" : undefined}>
            <p class="editorial-kicker">Terms & Conditions</p>
            <h2 class="editorial-title mt-3">Please confirm before booking.</h2>
            <ul class:list={["mt-6 grid gap-3", showActivitySupportSwipe && "activity-detail-support-list activity-detail-support-list--terms"]}>
              {item.terms.map((term) => (
                <li class:list={["rounded-[8px] border border-[#e5e0d6] bg-white/70 p-4 text-sm leading-6 text-[#4b5563]", isActivitiesTone && "activity-detail-support-item"]}>{term}</li>
              ))}
            </ul>
          </div>
        )}
      </div>

      {showActivitySupportSwipe && <SwipeControls count={activitySupportPanelCount} label="Service support and terms slider controls" breakpoint="mobile" className="activity-detail-support-controls mt-4" />}
    </div>
  </section>
)}
