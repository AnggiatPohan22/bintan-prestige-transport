---
import { ArrowUpRight, CalendarDays, MapPin, Tag } from "lucide-react";
import type { BlogArticle } from "@data/blog";

interface Props {
  article: BlogArticle;
  featured?: boolean;
  showFavoriteBadge?: boolean;
}

const { article, featured = false, showFavoriteBadge = true } = Astro.props;
---

<article
  class={`editorial-card blog-card group grid overflow-hidden rounded-[8px] transition duration-300 hover:-translate-y-1 hover:border-[#f8e7a1]/38 ${featured ? "blog-card--featured lg:grid-cols-[0.92fr_1.08fr]" : ""}`}
  data-blog-card
  data-blog-category={article.category}
  data-blog-location={article.location}
  data-blog-tags={article.tags.join("|")}
>
  <a class={`blog-card__media relative block overflow-hidden bg-[#071a14] ${featured ? "min-h-72 lg:min-h-full" : ""}`} href={`/blog/${article.slug}`} aria-label={`Read ${article.title}`}>
    <img class="blog-card__image absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.035]" src={article.heroImage} alt={article.heroAlt} loading={featured ? "eager" : "lazy"} />
    <div class="blog-card__shade absolute inset-0"></div>
    <div class="blog-card__badges absolute left-4 top-4 flex flex-wrap gap-2">
      <span class="blog-card__badge rounded-full border border-white/14 bg-black/30 px-3 py-1 text-xs font-semibold text-[#f8e7a1] backdrop-blur">{article.category}</span>
      {showFavoriteBadge && article.favorite && <span class="blog-card__badge gold-pill rounded-full px-3 py-1 text-xs font-semibold">Favorite</span>}
    </div>
  </a>

  <div class="blog-card__body flex min-w-0 flex-col p-5 sm:p-6">
    <div class="blog-card__meta flex flex-wrap gap-3 text-xs font-semibold text-slate-400">
      <span class="inline-flex items-center gap-1.5"><CalendarDays className="h-3.5 w-3.5 text-[#f8e7a1]" aria-hidden="true" /> {article.readTime}</span>
      <span class="inline-flex items-center gap-1.5"><MapPin className="h-3.5 w-3.5 text-[#f8e7a1]" aria-hidden="true" /> {article.location}</span>
    </div>
    <h2 class={`blog-card__title mt-4 font-[var(--font-editorial-heading)] font-medium leading-tight text-[#f8fafc] ${featured ? "text-3xl sm:text-4xl" : "text-2xl"}`}>
      <a class="transition hover:text-[#f8e7a1]" href={`/blog/${article.slug}`}>{article.title}</a>
    </h2>
    <p class="blog-card__excerpt mt-3 text-sm leading-7 text-slate-400">{article.excerpt}</p>
    <div class="blog-card__tags mt-5 flex flex-wrap gap-2">
      {article.tags.slice(0, featured ? 4 : 3).map((tag) => (
        <span class="blog-card__tag inline-flex items-center gap-1 rounded-full border border-[#bfa46f]/18 bg-[#bfa46f]/8 px-3 py-1 text-[11px] font-bold text-[#f8e7a1]/82">
          <Tag className="h-3 w-3" aria-hidden="true" />
          {tag}
        </span>
      ))}
    </div>
    <a class="blog-card__link mt-6 inline-flex w-fit items-center gap-2 text-sm font-extrabold text-[#f8e7a1] transition hover:text-[#fff4bd]" href={`/blog/${article.slug}`}>
      Read article
      <ArrowUpRight className="h-4 w-4" aria-hidden="true" />
    </a>
  </div>
</article>
