---
interface DetailItem {
  title: string;
  description: string;
  overview: string;
  image: string;
  alt: string;
  priceFrom?: string;
  duration?: string;
  capacity?: string;
  category?: string;
  mood?: string;
}

interface Props {
  item: DetailItem;
  parentLabel: string;
}

const { item, parentLabel } = Astro.props;
---

<section class="relative isolate overflow-hidden bg-[#0b0c10] text-white">
  <div
    class="absolute inset-0 -z-10 bg-cover bg-center"
    role="img"
    aria-label={item.alt}
    style={`background-image: linear-gradient(90deg, rgba(11,12,16,0.9), rgba(11,12,16,0.58), rgba(11,12,16,0.88)), linear-gradient(180deg, rgba(11,12,16,0.18), #0b0c10 92%), url('${item.image}');`}
  >
  </div>
  <div class="editorial-container grid min-h-[560px] items-end gap-8 py-16 md:grid-cols-[1fr_0.78fr] md:py-20">
    <div class="max-w-4xl">
      <p class="editorial-kicker">{parentLabel}</p>
      <h1 class="editorial-heading mt-4 max-w-[12ch] text-[#f8fafc]">{item.title}</h1>
      <p class="editorial-lede mt-5 text-slate-300">{item.overview}</p>
      <div class="mt-7 flex flex-wrap gap-2 text-xs font-bold text-slate-200">
        {item.priceFrom && <span class="gold-pill rounded-full px-3 py-1">{item.priceFrom}</span>}
        {item.duration && <span class="rounded-full border border-white/12 bg-black/24 px-3 py-1">{item.duration}</span>}
        {item.capacity && <span class="rounded-full border border-white/12 bg-black/24 px-3 py-1">{item.capacity}</span>}
      </div>
    </div>

    <aside class="editorial-card p-5 sm:p-6">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-[#f8e7a1]/72">{item.category ?? "package"}</p>
      <h2 class="mt-3 font-[var(--font-editorial-heading)] text-3xl font-medium leading-tight text-[#f8fafc]">
        {item.mood ?? "Private concierge package"}
      </h2>
      <p class="mt-4 text-sm leading-7 text-slate-400">{item.description}</p>
    </aside>
  </div>
</section>
