---
import { site } from "../../data/site";
import { tours } from "../../data/tours";
---

<div class="grid gap-4 lg:grid-cols-3">
  {tours.map((tour) => (
    <article class="editorial-card group overflow-hidden rounded-[8px] transition duration-300 hover:-translate-y-1 hover:border-[#f8e7a1]/38">
      <div class="visual-placeholder relative aspect-[16/10] overflow-hidden">
        <img
          class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.035]"
          src={tour.image}
          alt={tour.alt}
          loading="lazy"
        />
        <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(11,12,16,0.08),rgba(11,12,16,0.66))]" aria-hidden="true"></div>
        <div class="relative flex h-full items-start justify-between p-4">
          <span class="rounded-full border border-white/14 bg-black/28 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{tour.category}</span>
          <span class="rounded-full bg-[#e2e8f0] px-3 py-1 text-xs font-semibold text-[#0b0c10]">{tour.priceFrom}</span>
        </div>
      </div>
      <div class="p-5">
        <h3 class="font-[var(--font-editorial-heading)] text-2xl font-medium leading-tight text-[#f8fafc]">{tour.title}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-400">{tour.description}</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-slate-300">
          <span class="rounded-full border border-[#bfa46f]/24 bg-[#064e3b]/24 px-3 py-1 text-[#f8e7a1]">{tour.duration}</span>
          <span class="rounded-full border border-[#bfa46f]/24 bg-[#064e3b]/24 px-3 py-1 text-[#f8e7a1]">{tour.capacity}</span>
        </div>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a
            class="editorial-button-primary min-h-11 px-4"
            href={`/packages/island-tour/${tour.slug}`}
          >
            View detail
          </a>
          <a
            class="editorial-button-secondary min-h-11 px-4"
            href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(tour.whatsappMessage)}`}
            target="_blank"
            rel="noreferrer"
          >
            Ask availability
          </a>
        </div>
      </div>
    </article>
  ))}
</div>
