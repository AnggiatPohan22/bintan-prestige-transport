---
interface RouteItem {
  title: string;
  description: string;
  duration?: string;
  capacity?: string;
  category?: string;
  priceFrom?: string;
  whatsappMessage?: string;
}

interface Props {
  items: RouteItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-4">
  {items.map((item) => (
    <article class="rounded-[8px] border border-white/10 bg-[#111827]/72 p-5 shadow-[0_18px_55px_rgba(0,0,0,0.22)]">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div>
          {item.category && <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0]/56">{item.category}</p>}
          <h3 class="mt-1 text-lg font-semibold text-[#e2e8f0]">{item.title}</h3>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-400">{item.description}</p>
          <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-slate-300">
            {item.duration && <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1">{item.duration}</span>}
            {item.capacity && <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1">{item.capacity}</span>}
          </div>
        </div>
        {item.priceFrom && <span class="w-fit shrink-0 rounded-full bg-[#e2e8f0] px-4 py-2 text-sm font-semibold text-[#0b0c10]">{item.priceFrom}</span>}
      </div>
    </article>
  ))}
</div>
