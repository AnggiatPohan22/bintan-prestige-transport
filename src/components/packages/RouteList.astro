---
interface RouteItem {
  title: string;
  slug: string;
  description: string;
  image?: string;
  alt?: string;
  duration?: string;
  capacity?: string;
  category?: string;
  priceFrom?: string;
  whatsappMessage?: string;
}

interface Props {
  items: RouteItem[];
}

const { items } = Astro.props;

const getPriceDisplay = (value?: string) => {
  if (!value) {
    return null;
  }

  if (/^Depending Requests$/i.test(value)) {
    return {
      label: "Rate",
      price: "By Request",
    };
  }

  const startFromMatch = value.match(/^Start From\s*:\s*(.+)$/i);

  if (startFromMatch) {
    return {
      label: "Start From",
      price: startFromMatch[1],
    };
  }

  return {
    label: "Rate",
    price: value,
  };
};
---

<div class="grid gap-4">
  {items.map((item) => {
    const priceDisplay = getPriceDisplay(item.priceFrom);

    return (
      <article class="transfer-route-card group">
        {item.image && (
          <div class="transfer-route-card__media" aria-hidden="true">
            <img
              class="transfer-route-card__image"
              src={item.image}
              alt=""
              loading="lazy"
            />
          </div>
        )}
        <div class="transfer-route-card__body">
          <div class="min-w-0 max-w-2xl">
            {item.category && <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#f8e7a1]/62">{item.category}</p>}
            <h3 class="mt-2 font-[var(--font-editorial-heading)] text-[1.45rem] font-medium leading-tight text-[#f8fafc] sm:text-[1.7rem]">{item.title}</h3>
            <p class="mt-3 max-w-[44rem] text-sm leading-6 text-slate-300">{item.description}</p>
            <div class="mt-4 flex flex-wrap gap-2 text-xs font-bold text-slate-200">
              {item.duration && <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1">{item.duration}</span>}
              {item.capacity && <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1">{item.capacity}</span>}
            </div>
          </div>
          <div class="transfer-route-card__actions">
            {priceDisplay && (
              <div class="flex min-w-0 items-center gap-2.5">
                <span class="shrink-0 text-[0.68rem] font-bold uppercase tracking-[0.16em] text-[#f8e7a1]/64">{priceDisplay.label}</span>
                <span class="transfer-route-card__price">{priceDisplay.price}</span>
              </div>
            )}
            <a class="transfer-route-card__link" href={`/packages/pick-up-drop/${item.slug}`}>
              View detail
            </a>
          </div>
        </div>
      </article>
    );
  })}
</div>
