---
interface RouteItem {
  title: string;
  description: string;
  priceFrom?: string;
}

interface Props {
  items: RouteItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-3">
  {items.map((item) => (
    <article class="rounded-[8px] border border-slate-200 bg-white p-4 shadow-sm">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h3 class="font-semibold text-[#111317]">{item.title}</h3>
          <p class="mt-1 text-sm leading-6 text-slate-600">{item.description}</p>
        </div>
        {item.priceFrom && <span class="shrink-0 text-sm font-semibold text-[#c9a14a]">{item.priceFrom}</span>}
      </div>
    </article>
  ))}
</div>
