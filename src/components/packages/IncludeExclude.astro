---
interface Props {
  includes?: string[];
  excludes?: string[];
}

const {
  includes = ["Private car", "Driver", "Flexible route discussion"],
  excludes = ["Entrance ticket", "Meals", "Personal expenses"],
} = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  <div class="rounded-[8px] border border-slate-200 bg-white p-5">
    <h3 class="font-semibold text-[#111317]">Includes</h3>
    <ul class="mt-3 grid gap-2 text-sm text-slate-600">
      {includes.map((item) => <li>{item}</li>)}
    </ul>
  </div>
  <div class="rounded-[8px] border border-slate-200 bg-white p-5">
    <h3 class="font-semibold text-[#111317]">Excludes</h3>
    <ul class="mt-3 grid gap-2 text-sm text-slate-600">
      {excludes.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</div>
