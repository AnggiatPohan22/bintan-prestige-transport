---
interface Props {
  includes?: string[];
  excludes?: string[];
}

const {
  includes = ["Private car", "Private driver", "Route timing confirmation", "WhatsApp coordination", "Vehicle fit suggestion"],
  excludes = ["Parking fee if required", "Entrance ticket", "Meals", "Personal expenses", "Extra waiting beyond agreement"],
} = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  <div class="editorial-card editorial-card-warm p-5">
    <h3 class="font-[var(--font-editorial-heading)] text-2xl font-medium text-[#111827]">Includes</h3>
    <ul class="mt-4 grid gap-3 text-sm text-[#4b5563]">
      {includes.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#bfa46f]"></span><span>{item}</span></li>)}
    </ul>
  </div>
  <div class="editorial-card editorial-card-warm p-5">
    <h3 class="font-[var(--font-editorial-heading)] text-2xl font-medium text-[#111827]">Excludes</h3>
    <ul class="mt-4 grid gap-3 text-sm text-[#4b5563]">
      {excludes.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#064e3b]"></span><span>{item}</span></li>)}
    </ul>
  </div>
</div>
