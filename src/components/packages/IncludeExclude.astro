---
interface Props {
  includes?: string[];
  excludes?: string[];
}

const {
  includes = ["Private car", "Private driver", "Route timing confirmation", "WhatsApp coordination", "Vehicle fit suggestion"],
  excludes = ["Parking fee if required", "Entrance ticket", "Meals", "Personal expenses", "Extra waiting beyond agreement"],
} = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  <div class="rounded-[8px] border border-white/10 bg-[#111827]/72 p-5 shadow-[0_18px_55px_rgba(0,0,0,0.22)]">
    <h3 class="font-semibold text-[#e2e8f0]">Includes</h3>
    <ul class="mt-4 grid gap-3 text-sm text-slate-400">
      {includes.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#e2e8f0]"></span><span>{item}</span></li>)}
    </ul>
  </div>
  <div class="rounded-[8px] border border-white/10 bg-[#111827]/72 p-5 shadow-[0_18px_55px_rgba(0,0,0,0.22)]">
    <h3 class="font-semibold text-[#e2e8f0]">Excludes</h3>
    <ul class="mt-4 grid gap-3 text-sm text-slate-400">
      {excludes.map((item) => <li class="flex gap-3"><span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#064e3b]"></span><span>{item}</span></li>)}
    </ul>
  </div>
</div>
