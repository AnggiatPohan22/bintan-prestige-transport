---
import { Clock, Luggage, MapPin, MessageCircle } from "lucide-react";
import { site } from "../../data/site";

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(
  "Hello, I want to check availability for Pick Up & Drop transfer service.",
)}`;

const points = [
  { label: "Airport, ferry, hotel", icon: MapPin },
  { label: "Private driver timing", icon: Clock },
  { label: "Luggage-aware vehicle", icon: Luggage },
];
---

<section class="relative overflow-hidden border-b border-white/10 bg-[#0b0c10]">
  <div class="absolute inset-0 visual-placeholder opacity-80"></div>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(11,12,16,0.58),#0b0c10_88%)]"></div>
  <div class="container-page relative grid min-h-[620px] gap-8 py-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-16">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#e2e8f0]/64">Premium transfer service</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-[1.05] text-[#e2e8f0] sm:text-5xl lg:text-6xl">
        Pick Up & Drop with private driver comfort.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
        Airport, ferry terminal, resort, dinner, and custom point-to-point movement for guests who want the route handled clearly before they arrive.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-[#e2e8f0] px-6 text-sm font-semibold text-[#0b0c10] shadow-[0_0_34px_rgba(226,232,240,0.18)] transition hover:bg-white" href={href} target="_blank" rel="noreferrer">
          <MessageCircle className="h-4 w-4" aria-hidden="true" />
          <span>Check Availability</span>
        </a>
        <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/18 bg-white/5 px-6 text-sm font-semibold text-[#e2e8f0] backdrop-blur transition hover:bg-white/10" href="#transfer-routes">
          View Transfer Routes
        </a>
      </div>
    </div>

    <div class="luxury-surface silver-glow rounded-[8px] p-5 sm:p-6">
      <p class="text-sm font-semibold text-[#e2e8f0]">Transfer ready for</p>
      <div class="mt-5 grid gap-3">
        {points.map((point) => {
          const Icon = point.icon;
          return (
            <div class="flex items-center gap-3 rounded-[8px] border border-white/10 bg-white/[0.03] p-4">
              <Icon className="h-5 w-5 text-[#e2e8f0]/72" aria-hidden="true" />
              <span class="text-sm font-medium text-slate-300">{point.label}</span>
            </div>
          );
        })}
      </div>
      <div class="mt-5 rounded-[8px] border border-[#064e3b]/50 bg-[#064e3b]/24 p-4">
        <p class="text-sm leading-6 text-emerald-100">
          Share pickup point, drop point, passenger count, luggage count, and target time. The first booking flow stays simple through WhatsApp.
        </p>
      </div>
    </div>
  </div>
</section>
