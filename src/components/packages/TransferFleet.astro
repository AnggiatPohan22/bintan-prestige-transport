---
import { carTypes } from "../../data/carTypes";
---

<div class="grid gap-4 lg:grid-cols-3">
  {carTypes.map((car) => (
    <article class="overflow-hidden rounded-[8px] border border-white/10 bg-[#111827]/72 shadow-[0_18px_55px_rgba(0,0,0,0.24)]">
      <div
        class="visual-placeholder aspect-[16/10] bg-cover bg-center"
        role="img"
        aria-label={car.alt}
        style={`background-image: linear-gradient(135deg, rgba(11,12,16,0.08), rgba(11,12,16,0.7)), url('${car.image}');`}
      >
        <div class="flex h-full items-start justify-between p-4">
          <span class="rounded-full border border-white/14 bg-black/28 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{car.category}</span>
          <span class="rounded-full bg-[#e2e8f0] px-3 py-1 text-xs font-semibold text-[#0b0c10]">{car.priceFrom}</span>
        </div>
      </div>
      <div class="p-5">
        <h3 class="text-lg font-semibold text-[#e2e8f0]">{car.name}</h3>
        <p class="mt-1 text-sm font-medium text-emerald-100/80">{car.type}</p>
        <p class="mt-3 text-sm leading-6 text-slate-400">{car.shortDescription}</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-slate-300">
          <span class="rounded-full border border-white/10 px-3 py-1">{car.capacity}</span>
          <span class="rounded-full border border-white/10 px-3 py-1">{car.luggage}</span>
        </div>
      </div>
    </article>
  ))}
</div>
