---
import { transportRoutes } from "../../data/transportRoutes";
---

<div class="grid gap-4 md:grid-cols-2">
  {transportRoutes.map((route) => (
    <article class="fleet-route-card group">
      <div class="fleet-route-card__media">
        <img
          class="fleet-route-card__image"
          src={route.image}
          alt={route.alt}
          loading="lazy"
        />
        <div class="fleet-route-card__shade" aria-hidden="true"></div>
        <div class="relative flex h-full items-start justify-between gap-3 p-4">
          <span class="rounded-full border border-white/14 bg-black/28 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{route.badge}</span>
          <span class="rounded-full bg-[#f8e7a1] px-3 py-1 text-xs font-extrabold text-[#0b0c10]">{route.vehicle}</span>
        </div>
      </div>
      <div class="p-5 sm:p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#bfa46f]">{route.vehicle}</p>
        <h3 class="mt-2 text-xl font-semibold text-[#e2e8f0]">{route.title}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-400">{route.description}</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold text-slate-300">
          <span class="rounded-full border border-white/10 px-3 py-1">{route.duration}</span>
          <span class="rounded-full border border-white/10 px-3 py-1">{route.capacity}</span>
        </div>
      </div>
    </article>
  ))}
</div>
