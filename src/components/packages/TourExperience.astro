---
const items = [
  {
    title: "Scenic beaches",
    description: "Prepare visual slots for premium beach stops, calm routes, and destination photography.",
  },
  {
    title: "Culture and local stops",
    description: "Support flexible stops for local food, culture, shopping, and guest-paced discovery.",
  },
  {
    title: "Night tour option",
    description: "Position dinner and evening routes without forcing a heavy itinerary builder yet.",
  },
  {
    title: "Private route control",
    description: "Keep the experience private, timed, and easy to adjust through WhatsApp coordination.",
  },
];
---

<div class="grid gap-4 md:grid-cols-2">
  {items.map((item, index) => (
    <article class="relative overflow-hidden rounded-[8px] border border-white/10 bg-[#111827]/72 p-5 shadow-[0_18px_55px_rgba(0,0,0,0.22)]">
      <div class="absolute right-5 top-5 text-xs font-semibold text-[#e2e8f0]/28">0{index + 1}</div>
      <h3 class="pr-10 text-lg font-semibold text-[#e2e8f0]">{item.title}</h3>
      <p class="mt-3 text-sm leading-6 text-slate-400">{item.description}</p>
    </article>
  ))}
</div>
