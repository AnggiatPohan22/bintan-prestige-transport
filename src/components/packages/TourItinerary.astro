---
interface Props {
  items?: string[];
}

const { items = ["Hotel pick up", "Scenic route", "Main destination stops", "Hotel drop off"] } = Astro.props;
---

<ol class="grid gap-3">
  {items.map((item, index) => (
    <li class="flex gap-3 rounded-[8px] border border-white/10 bg-[#111827]/72 p-4 text-sm text-slate-400 shadow-[0_18px_55px_rgba(0,0,0,0.18)]">
      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#e2e8f0] text-xs font-semibold text-[#0b0c10]">{index + 1}</span>
      <span class="leading-6">{item}</span>
    </li>
  ))}
</ol>
