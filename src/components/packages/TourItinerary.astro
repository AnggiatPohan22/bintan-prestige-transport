---
interface Props {
  items?: string[];
}

const { items = ["Hotel pick up", "Scenic route", "Main destination stops", "Hotel drop off"] } = Astro.props;
---

<ol class="grid gap-3">
  {items.map((item, index) => (
    <li class="editorial-card editorial-card-warm flex gap-3 rounded-[8px] p-4 text-sm text-[#4b5563]">
      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-[8px] border border-[#bfa46f]/28 bg-[#bfa46f]/14 text-xs font-extrabold text-[#8f6b2b]">{String(index + 1).padStart(2, "0")}</span>
      <span class="leading-6">{item}</span>
    </li>
  ))}
</ol>
