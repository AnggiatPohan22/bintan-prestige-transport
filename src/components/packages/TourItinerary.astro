---
interface Props {
  items?: string[];
}

const { items = ["Hotel pick up", "Scenic route", "Main destination stops", "Hotel drop off"] } = Astro.props;
---

<ol class="grid gap-3">
  {items.map((item, index) => (
    <li class="flex gap-3 rounded-[8px] border border-slate-200 bg-white p-4 text-sm text-slate-700">
      <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#111317] text-xs font-semibold text-white">{index + 1}</span>
      <span>{item}</span>
    </li>
  ))}
</ol>
