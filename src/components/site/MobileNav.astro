---
import { ArrowUpRight, Menu, MessageCircle, X } from "lucide-react";
import { navigation } from "@data/navigation";
import { site } from "@data/site";

const whatsappHref = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const menuDescriptions: Record<string, string> = {
  "/": "Editorial overview",
  "/packages/pick-up-drop": "Private transfer",
  "/packages/activities-packages": "Activities",
  "/blog": "Travel guides",
  "/about": "Brand story",
  "/contact": "Concierge contact",
};

const isActive = (href: string) => {
  const normalizedHref = href.replace(/\/$/, "") || "/";

  if (normalizedHref === "/") {
    return currentPath === "/";
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};
---

<details class="mobile-menu relative z-[90] md:hidden" data-mobile-menu>
  <summary
    class="mobile-menu-trigger"
    aria-label="Toggle navigation menu"
    data-mobile-menu-trigger
  >
    <Menu className="mobile-menu-open-icon h-5 w-5" aria-hidden="true" />
    <X className="mobile-menu-close-icon h-5 w-5" aria-hidden="true" />
  </summary>

  <button class="mobile-menu-backdrop md:hidden" type="button" aria-label="Close navigation menu" data-mobile-menu-backdrop></button>
  <div class="mobile-menu-panel md:hidden" data-mobile-menu-panel>
    <div class="mobile-menu-panel__glow"></div>
    <div class="mobile-menu-panel__header">
      <p class="mobile-menu-panel__kicker">Bintan Prestige</p>
      <p class="mobile-menu-panel__title">
        {site.shortName}
      </p>
      <p class="mobile-menu-panel__copy">Private taxi, tour, transfer, and activity planning.</p>
    </div>

    <div class="mobile-menu-panel__links">
      {navigation.map((item) => (
        <a
          class:list={["mobile-menu-link group", isActive(item.href) && "is-active"]}
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          <span class="mobile-menu-link__body">
            <span>{item.label}</span>
            <small>{menuDescriptions[item.href] ?? "Explore"}</small>
          </span>
          <ArrowUpRight className="mobile-menu-link__icon" aria-hidden="true" />
        </a>
      ))}

      <a class="mobile-menu-whatsapp" href={whatsappHref} rel="noreferrer" target="_blank">
        <MessageCircle className="h-4 w-4" aria-hidden="true" />
        <span>Chat on WhatsApp</span>
      </a>

      <div class="mobile-menu-panel__meta">
        <span>{site.responseWindow}</span>
        <span>Premium Service</span>
      </div>
    </div>
  </div>
</details>

<script>
  import { pageScrollLock } from "../../scripts/pageScrollLock";

  const mobileMenu = document.querySelector<HTMLDetailsElement>("[data-mobile-menu]");
  const mobileMenuPanel = mobileMenu?.querySelector<HTMLElement>("[data-mobile-menu-panel]");
  const mobileMenuTrigger = mobileMenu?.querySelector<HTMLElement>("[data-mobile-menu-trigger]");
  const mobileMenuBackdrop = mobileMenu?.querySelector<HTMLButtonElement>("[data-mobile-menu-backdrop]");

  const setMobileMenuOpen = (isOpen: boolean) => {
    if (!mobileMenu) return;

    mobileMenu.open = isOpen;
    document.documentElement.classList.toggle("mobile-menu-is-open", isOpen);
    if (isOpen) {
      pageScrollLock.lock("mobile-menu");
    } else {
      pageScrollLock.unlock("mobile-menu");
    }
    document.dispatchEvent(new CustomEvent(isOpen ? "mobile-menu:open" : "mobile-menu:close"));
  };

  mobileMenu?.addEventListener("toggle", () => {
    const isOpen = Boolean(mobileMenu.open);
    document.documentElement.classList.toggle("mobile-menu-is-open", isOpen);
    if (isOpen) {
      pageScrollLock.lock("mobile-menu");
    } else {
      pageScrollLock.unlock("mobile-menu");
    }
    document.dispatchEvent(new CustomEvent(isOpen ? "mobile-menu:open" : "mobile-menu:close"));
  });

  mobileMenuBackdrop?.addEventListener("click", () => {
    setMobileMenuOpen(false);
    mobileMenuTrigger?.focus({ preventScroll: true });
  });

  document.addEventListener("pointerdown", (event) => {
    if (!mobileMenu?.open) return;

    const target = event.target as Node | null;
    if (!target) return;
    if (mobileMenuPanel?.contains(target) || mobileMenuTrigger?.contains(target)) return;

    setMobileMenuOpen(false);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || !mobileMenu?.open) return;

    setMobileMenuOpen(false);
    mobileMenuTrigger?.focus({ preventScroll: true });
  });

  window.addEventListener("pagehide", () => {
    document.documentElement.classList.remove("mobile-menu-is-open");
    pageScrollLock.unlock("mobile-menu");
  });
</script>
