---
import { ArrowUp, ArrowUpRight, Bot, Compass, MessageCircle, Phone, Plus, Send, Sparkles, X } from "lucide-react";
import { site } from "@data/site";
import PromoTicker from "@components/core/PromoTicker.astro";

const href = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
const phoneHref = `tel:${site.phone.replace(/[^\d+]/g, "")}`;
const fabActions = [
  {
    label: "WA",
    kind: "whatsapp",
    Icon: MessageCircle,
    ariaLabel: "Open WhatsApp concierge",
  },
  {
    label: "Book tour",
    kind: "link",
    href: "/packages/activities-packages",
    Icon: Compass,
    ariaLabel: "Open activities package page",
  },
  {
    label: "Call direct",
    kind: "link",
    href: phoneHref,
    Icon: Phone,
    ariaLabel: `Call ${site.shortName}`,
  },
];
const getFabStyle = (index: number, count: number) => {
  const referenceLayout = [
    { x: -0.15, y: -5.45 },
    { x: -3.85, y: -2.8 },
    { x: -4.72, y: 0.42 },
  ];

  if (count === referenceLayout.length) {
    const point = referenceLayout[index];
    const delay = 40 + index * 46;

    return `--fab-x: ${point.x.toFixed(2)}rem; --fab-y: ${point.y.toFixed(2)}rem; --fab-delay: ${delay}ms;`;
  }

  const progress = count === 1 ? 0.5 : (index + 1) / (count + 1);
  const curve = 4;
  const lift = (count - index - 1) * 2.75 + 5.1;
  const x = -(0.3 + Math.sin(progress * Math.PI) * curve);
  const delay = 40 + index * 46;

  return `--fab-x: ${x.toFixed(2)}rem; --fab-y: -${lift.toFixed(2)}rem; --fab-delay: ${delay}ms;`;
};
const quickMessages = [
  {
    label: "Check transfer price",
    answer: "I can help prepare a price request. Please add your pickup, drop-off, date, time, and guest count.",
    message:
      "Hello Bintan Prestige, I want to check the price for a private transfer.\n\nPickup point: -\nDrop-off point: -\nTravel date: -\nPreferred time: -\nGuests: -\nLuggage: -\n\nPlease confirm availability and estimated price.",
  },
  {
    label: "Plan activities",
    answer: "Good choice. I can prepare an activity request for Bintan highlights, beach stops, snorkeling, spa, golf, or custom routes.",
    message:
      "Hello Bintan Prestige, I want to plan an activities package in Bintan.\n\nPreferred activity: -\nPickup point: -\nTravel date: -\nPreferred time: -\nGuests: -\n\nPlease recommend a suitable package and confirm availability.",
  },
  {
    label: "Need recommendation",
    answer: "Tell us your arrival point and schedule. We can suggest the route, vehicle, and package that fits best.",
    message:
      "Hello Bintan Prestige, I need a recommendation for private taxi or tour service.\n\nArrival / pickup point: -\nDestination or places I want to visit: -\nTravel date: -\nPreferred time: -\nGuests: -\n\nPlease suggest the best option.",
  },
  {
    label: "Airport or ferry pickup",
    answer: "I can prepare a pickup request. Share arrival point, arrival time, destination, and guest count.",
    message:
      "Hello Bintan Prestige, I want to arrange airport or ferry pickup.\n\nArrival point: -\nArrival date: -\nArrival time: -\nDestination: -\nGuests: -\nLuggage: -\n\nPlease confirm pickup availability.",
  },
  {
    label: "Custom route",
    answer: "Custom routes are possible. Add your preferred stops and we will help shape the timing.",
    message:
      "Hello Bintan Prestige, I want to request a custom private route.\n\nPickup point: -\nPreferred stops: -\nDrop-off / return plan: -\nTravel date: -\nGuests: -\n\nPlease help arrange the route and estimate the price.",
  },
];
---

<div
  class="whatsapp-assistant fixed bottom-[calc(4.75rem+env(safe-area-inset-bottom))] right-4 z-40 sm:bottom-[4.75rem] lg:bottom-[4.5rem]"
  data-whatsapp-assistant
  data-whatsapp-number={site.whatsappNumber}
  data-default-message={site.whatsappMessage}
>
  <section class="whatsapp-assistant-panel" data-whatsapp-panel hidden aria-label="WhatsApp concierge chat">
    <div class="whatsapp-assistant-panel__glow" aria-hidden="true"></div>
    <div class="whatsapp-assistant-panel__header">
      <div class="whatsapp-assistant-avatar" aria-hidden="true">
        <Bot className="h-5 w-5" />
      </div>
      <div class="min-w-0">
        <p class="whatsapp-assistant-kicker">Bintan Prestige Concierge</p>
        <h2 class="whatsapp-assistant-title">How can we help?</h2>
        <p class="whatsapp-assistant-status"><span></span> Online assistant template</p>
      </div>
      <button class="whatsapp-assistant-close" type="button" data-whatsapp-close aria-label="Close WhatsApp chat">
        <X className="h-4 w-4" aria-hidden="true" />
      </button>
    </div>

    <div class="whatsapp-assistant-bubble" data-whatsapp-answer>
      Hi, choose a question below and I will prepare a clean WhatsApp message for you.
    </div>

    <div class="whatsapp-assistant-quick-grid">
      {quickMessages.map((item) => (
        <button
          class="whatsapp-assistant-quick"
          type="button"
          data-whatsapp-quick={item.message}
          data-whatsapp-answer-text={item.answer}
        >
          <Sparkles className="h-3.5 w-3.5" aria-hidden="true" />
          <span>{item.label}</span>
        </button>
      ))}
    </div>

    <label class="whatsapp-assistant-field">
      <span class="sr-only">WhatsApp message</span>
      <textarea class="whatsapp-assistant-textarea" data-whatsapp-message>{site.whatsappMessage}</textarea>
    </label>

    <a class="whatsapp-assistant-submit" href={href} target="_blank" rel="noreferrer" data-whatsapp-link>
      <Send className="h-4 w-4" aria-hidden="true" />
      <span>Continue to WhatsApp</span>
      <ArrowUpRight className="h-4 w-4" aria-hidden="true" />
    </a>

    <PromoTicker className="whatsapp-assistant-promo" />
  </section>

  <div class="whatsapp-assistant-actions" aria-label="Floating quick actions">
    <div class="whatsapp-assistant-fab-menu" data-fab-menu aria-label="Floating action shortcuts">
      {fabActions.map((item, index) => {
        const Icon = item.Icon;
        const style = getFabStyle(index, fabActions.length);

        return (
          <div class="whatsapp-assistant-fab-item" style={style}>
            {item.kind === "whatsapp" ? (
              <button class="whatsapp-assistant-fab-link" type="button" data-whatsapp-open aria-label={item.ariaLabel}>
                <span class="whatsapp-assistant-fab-label">{item.label}</span>
                <span class="whatsapp-assistant-fab-icon" aria-hidden="true">
                  <Icon className="h-4 w-4" aria-hidden="true" />
                </span>
              </button>
            ) : (
              <a class="whatsapp-assistant-fab-link" href={item.href} aria-label={item.ariaLabel}>
                <span class="whatsapp-assistant-fab-label">{item.label}</span>
                <span class="whatsapp-assistant-fab-icon" aria-hidden="true">
                  <Icon className="h-4 w-4" aria-hidden="true" />
                </span>
              </a>
            )}
          </div>
        );
      })}
    </div>

    <button class="whatsapp-assistant-toggle" type="button" data-fab-toggle aria-expanded="false" aria-label="Open contact shortcuts">
      <span class="whatsapp-assistant-toggle__pulse" aria-hidden="true"></span>
      <Plus className="whatsapp-assistant-toggle__icon h-5 w-5" aria-hidden="true" />
    </button>
    <button class="scroll-top-toggle" type="button" data-scroll-top aria-label="Back to top">
      <ArrowUp className="h-4 w-4" aria-hidden="true" />
    </button>
  </div>
</div>

<script>
  const assistant = document.querySelector<HTMLElement>("[data-whatsapp-assistant]");
  const panel = assistant?.querySelector<HTMLElement>("[data-whatsapp-panel]");
  const fabMenu = assistant?.querySelector<HTMLElement>("[data-fab-menu]");
  const toggle = assistant?.querySelector<HTMLButtonElement>("[data-fab-toggle]");
  const whatsappOpen = assistant?.querySelector<HTMLButtonElement>("[data-whatsapp-open]");
  const scrollTopButton = assistant?.querySelector<HTMLButtonElement>("[data-scroll-top]");
  const close = assistant?.querySelector<HTMLButtonElement>("[data-whatsapp-close]");
  const textarea = assistant?.querySelector<HTMLTextAreaElement>("[data-whatsapp-message]");
  const link = assistant?.querySelector<HTMLAnchorElement>("[data-whatsapp-link]");
  const answer = assistant?.querySelector<HTMLElement>("[data-whatsapp-answer]");
  const quickButtons = assistant?.querySelectorAll<HTMLButtonElement>("[data-whatsapp-quick]");
  let panelTransitionTimer: number | undefined;
  let previousHtmlOverflow = "";
  let previousBodyOverflow = "";
  let previousBodyPaddingRight = "";
  let isFabMenuOpen = false;

  const setFabMenuOpen = (isOpen: boolean) => {
    if (!assistant || !toggle || !fabMenu) return;

    isFabMenuOpen = isOpen;
    assistant.dataset.menuOpen = String(isOpen);
    toggle.setAttribute("aria-expanded", String(isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Close contact shortcuts" : "Open contact shortcuts");
  };

  const lockPageScroll = () => {
    if (document.documentElement.classList.contains("whatsapp-scroll-locked")) return;

    const scrollbarWidth = Math.max(0, window.innerWidth - document.documentElement.clientWidth);
    previousHtmlOverflow = document.documentElement.style.overflow;
    previousBodyOverflow = document.body.style.overflow;
    previousBodyPaddingRight = document.body.style.paddingRight;
    document.documentElement.classList.add("whatsapp-scroll-locked");
    document.documentElement.style.overflow = "hidden";
    document.body.style.overflow = "hidden";
    if (scrollbarWidth > 0) {
      document.body.style.paddingRight = `${scrollbarWidth}px`;
    }
  };

  const unlockPageScroll = () => {
    if (!document.documentElement.classList.contains("whatsapp-scroll-locked")) return;

    document.documentElement.classList.remove("whatsapp-scroll-locked");
    document.documentElement.style.overflow = previousHtmlOverflow;
    document.body.style.overflow = previousBodyOverflow;
    document.body.style.paddingRight = previousBodyPaddingRight;
  };

  const updateWhatsAppLink = () => {
    if (!assistant || !textarea || !link) return;

    const phone = assistant.dataset.whatsappNumber ?? "";
    const message = textarea.value.trim() || assistant.dataset.defaultMessage || "Hello, I need travel assistance.";
    link.href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
  };

  const setPanelOpen = (isOpen: boolean) => {
    if (!panel || !toggle) return;

    window.clearTimeout(panelTransitionTimer);
    assistant?.setAttribute("data-open", String(isOpen));
    if (isOpen) {
      setFabMenuOpen(false);
    }

    if (isOpen) {
      lockPageScroll();
      panel.hidden = false;
      updateWhatsAppLink();
      window.requestAnimationFrame(() => {
        panel.dataset.state = "open";
      });
      panelTransitionTimer = window.setTimeout(() => {
        if (window.matchMedia("(min-width: 640px)").matches) {
          textarea?.focus({ preventScroll: true });
        }
      }, 180);
      return;
    }

    panel.dataset.state = "closed";
    unlockPageScroll();
    panelTransitionTimer = window.setTimeout(() => {
      panel.hidden = true;
    }, 240);
  };

  const updateScrollTopButton = () => {
    if (!scrollTopButton) return;

    scrollTopButton.classList.toggle("is-visible", window.scrollY > 420);
  };

  toggle?.addEventListener("click", () => {
    setFabMenuOpen(!isFabMenuOpen);
  });

  whatsappOpen?.addEventListener("click", () => {
    setPanelOpen(true);
  });

  scrollTopButton?.addEventListener("click", () => {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    window.scrollTo({
      top: 0,
      behavior: reduceMotion ? "auto" : "smooth",
    });
  });

  close?.addEventListener("click", () => {
    setPanelOpen(false);
  });

  textarea?.addEventListener("input", updateWhatsAppLink);

  quickButtons?.forEach((button) => {
    button.addEventListener("click", () => {
      if (!textarea) return;

      textarea.value = button.dataset.whatsappQuick ?? "";
      if (answer) {
        answer.textContent = button.dataset.whatsappAnswerText ?? "I prepared a WhatsApp message for you.";
        answer.dataset.updated = "true";
        window.setTimeout(() => {
          delete answer.dataset.updated;
        }, 360);
      }
      updateWhatsAppLink();
      textarea.focus({ preventScroll: true });
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      if (panel && !panel.hidden) {
        setPanelOpen(false);
        return;
      }
      setFabMenuOpen(false);
    }
  });

  updateWhatsAppLink();
  updateScrollTopButton();
  window.addEventListener("scroll", updateScrollTopButton, { passive: true });
  window.addEventListener("pagehide", unlockPageScroll);
</script>
