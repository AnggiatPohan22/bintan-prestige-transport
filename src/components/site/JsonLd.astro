---
interface Props {
  data?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { data } = Astro.props;
const graph = Array.isArray(data) ? data : data ? [data] : [];
const payload = graph.length
  ? {
      "@context": "https://schema.org",
      "@graph": graph,
    }
  : undefined;
---

{payload && <script is:inline type="application/ld+json" set:html={JSON.stringify(payload)} />}
