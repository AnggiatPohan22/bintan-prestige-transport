---
const signals = [
  { value: "Private", label: "Taxi, tour, and activity movement without shared ride pressure" },
  { value: "Bintan", label: "Route familiarity for Lagoi, Trikora, Tanjung Pinang, ferry, and airport areas" },
  { value: "Flexible", label: "Custom pickup, return plan, waiting time, and stop requests by WhatsApp" },
  { value: "Premium", label: "Comfort-minded vehicles, polite driver support, and clear trip coordination" },
];
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {signals.map((item) => (
    <article class="editorial-card editorial-card-warm rounded-[8px] p-5 transition duration-300 hover:-translate-y-0.5">
      <p class="font-[var(--font-editorial-heading)] text-2xl font-medium text-[#111827]">{item.value}</p>
      <p class="mt-3 text-sm leading-6 text-[#4b5563]">{item.label}</p>
    </article>
  ))}
</div>
