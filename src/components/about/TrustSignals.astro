---
const signals = [
  { value: "Static-first", label: "Fast public pages" },
  { value: "WhatsApp", label: "Human-first booking" },
  { value: "Private", label: "Transfer and tour focus" },
  { value: "Future CMS", label: "API-ready data shape" },
];
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
  {signals.map((item) => (
    <article class="editorial-card editorial-card-warm rounded-[8px] p-5 text-center transition duration-300 hover:-translate-y-0.5">
      <p class="font-[var(--font-editorial-heading)] text-2xl font-medium text-[#111827]">{item.value}</p>
      <p class="mt-2 text-sm text-[#6b7280]">{item.label}</p>
    </article>
  ))}
</div>
