---
import { packages } from "../../data/packages";
import { site } from "../../data/site";
---

<div class="grid gap-4 md:grid-cols-2">
  {packages.map((item) => (
    <article class="group overflow-hidden rounded-[8px] border border-white/10 bg-[#111827]/70 shadow-[0_24px_70px_rgba(0,0,0,0.28)] transition duration-300 hover:-translate-y-1 hover:border-[#e2e8f0]/24">
      <div
        class="visual-placeholder aspect-[16/10] bg-cover bg-center"
        role="img"
        aria-label={item.alt}
        style={`background-image: linear-gradient(135deg, rgba(11,12,16,0.1), rgba(11,12,16,0.62)), url('${item.image}');`}
      >
        <div class="flex h-full items-start justify-between p-5">
          <span class="rounded-full border border-white/14 bg-black/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{item.category}</span>
          <span class="rounded-full bg-[#064e3b]/78 px-3 py-1 text-xs font-semibold text-[#e2e8f0]">{item.priceFrom}</span>
        </div>
      </div>
      <div class="p-5 sm:p-6">
        <h3 class="text-xl font-semibold text-[#e2e8f0]">{item.title}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-400">{item.description}</p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a class="inline-flex min-h-11 items-center justify-center rounded-full bg-[#e2e8f0] px-4 text-sm font-semibold text-[#0b0c10] transition hover:bg-white" href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(item.whatsappMessage)}`} target="_blank" rel="noreferrer">Reserve</a>
          <a class="inline-flex min-h-11 items-center justify-center rounded-full border border-white/12 px-4 text-sm font-semibold text-[#e2e8f0] transition hover:bg-white/8" href={`/packages/${item.slug}`}>View details</a>
        </div>
      </div>
    </article>
  ))}
</div>
