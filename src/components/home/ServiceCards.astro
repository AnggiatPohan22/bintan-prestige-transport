---
import { packages } from "../../data/packages";
import { site } from "../../data/site";
---

<div class="grid gap-5 md:grid-cols-2">
  {packages.map((item) => (
    <article class="editorial-card group overflow-hidden rounded-[8px] transition duration-300 hover:-translate-y-1 hover:border-[#f8e7a1]/38">
      <div
        class="visual-placeholder aspect-[16/10] bg-cover bg-center transition duration-500 group-hover:scale-[1.02]"
        role="img"
        aria-label={item.alt}
        style={`background-image: linear-gradient(180deg, rgba(11,12,16,0.04), rgba(11,12,16,0.76)), url('${item.image}');`}
      >
        <div class="flex h-full items-start justify-between p-5">
          <span class="rounded-full border border-white/14 bg-black/30 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{item.category}</span>
          <span class="gold-pill rounded-full px-3 py-1 text-xs font-semibold">{item.priceFrom}</span>
        </div>
      </div>
      <div class="p-5 sm:p-6">
        <h3 class="font-[var(--font-editorial-heading)] text-2xl font-medium leading-tight text-[#f8fafc] sm:text-3xl">{item.title}</h3>
        <p class="mt-3 text-sm leading-6 text-slate-400">{item.description}</p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a class="editorial-button-primary min-h-11 px-4" href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(item.whatsappMessage)}`} target="_blank" rel="noreferrer">Reserve</a>
          <a class="editorial-button-secondary min-h-11 px-4" href={`/packages/${item.slug}`}>View details</a>
        </div>
      </div>
    </article>
  ))}
</div>
