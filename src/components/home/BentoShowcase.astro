---
const items = [
  {
    title: "VIP Airport Transfer",
    label: "Arrival",
    description: "Calm airport pickup with private driver timing and luggage support.",
    className: "md:col-span-2",
  },
  {
    title: "Private Island Tour",
    label: "Explore",
    description: "Flexible day routes for beaches, viewpoints, culture, and food stops.",
    className: "",
  },
  {
    title: "Luxury Night Ride",
    label: "After dark",
    description: "Premium evening transfer for dinner, resort, or night route requests.",
    className: "",
  },
  {
    title: "Premium Fleet",
    label: "Comfort",
    description: "Sedan, MPV, and van options shaped for private travel comfort.",
    className: "md:col-span-2",
  },
  {
    title: "Local Concierge",
    label: "Guidance",
    description: "Route suggestions and flexible timing from local trip knowledge.",
    className: "lg:col-span-2",
  },
  {
    title: "Flexible Itinerary",
    label: "Custom",
    description: "Start with WhatsApp and shape the route around your schedule.",
    className: "",
  },
];
---

<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
  {items.map((item, index) => (
    <article class={`group relative min-h-48 overflow-hidden rounded-[8px] border border-[#bfa46f]/24 bg-[#071a14]/82 p-5 shadow-[0_22px_65px_rgba(0,0,0,0.28)] transition duration-300 hover:border-[#f8e7a1]/38 ${item.className}`}>
      <div class="absolute inset-0 -z-10 opacity-80 visual-placeholder"></div>
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(140deg,rgba(11,12,16,0.34),rgba(11,12,16,0.88))]"></div>
      <span class="rounded-full border border-white/14 bg-black/24 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0]/80">{item.label}</span>
      <h3 class="mt-8 max-w-sm text-2xl font-semibold leading-tight text-[#e2e8f0]">{item.title}</h3>
      <p class="mt-3 max-w-md text-sm leading-6 text-[#c7d2c3]">{item.description}</p>
      <span class="absolute bottom-5 right-5 text-xs font-semibold text-[#e2e8f0]/40">0{index + 1}</span>
    </article>
  ))}
</div>
