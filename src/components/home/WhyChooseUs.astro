---
import FeatureCard from "../common/FeatureCard.astro";

const features = [
  {
    title: "Concierge-first booking",
    description: "Visitors move from premium trip intent to WhatsApp availability checks quickly.",
  },
  {
    title: "Static-first performance",
    description: "Astro keeps the public website fast while React is reserved for selective interaction.",
  },
  {
    title: "Premium travel framing",
    description: "Copy, cards, and data shape support transfers, tours, VIP driving, and future CMS content.",
  },
];
---

<div class="home-scroll-row home-scroll-row-3 md:grid md:grid-cols-3">
  {features.map((feature) => (
    <div class="home-scroll-card">
      <FeatureCard {...feature} />
    </div>
  ))}
</div>
