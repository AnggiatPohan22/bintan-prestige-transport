---
import { routes } from "../../data/routes";
import { tours } from "../../data/tours";
import { site } from "../../data/site";

const items = [...routes.slice(0, 2), ...tours.slice(0, 2)];
---

<div class="grid gap-4 md:grid-cols-2">
  {items.map((item) => (
    <article class="group overflow-hidden rounded-[8px] border border-white/10 bg-[#111827]/70 shadow-[0_18px_60px_rgba(0,0,0,0.24)] transition duration-300 hover:-translate-y-1 hover:border-[#e2e8f0]/24">
      <div
        class="visual-placeholder aspect-[16/9] bg-cover bg-center"
        role="img"
        aria-label={item.alt}
        style={`background-image: linear-gradient(135deg, rgba(11,12,16,0.1), rgba(11,12,16,0.68)), url('${item.image}');`}
      >
        <div class="flex h-full items-start justify-between p-4">
          <span class="rounded-full border border-white/14 bg-black/28 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{item.category}</span>
          <span class="rounded-full bg-[#e2e8f0] px-3 py-1 text-xs font-semibold text-[#0b0c10]">{item.priceFrom}</span>
        </div>
      </div>
      <div class="p-5">
        <h3 class="text-lg font-semibold text-[#e2e8f0]">{item.title}</h3>
        <p class="mt-2 text-sm leading-6 text-slate-400">{item.description}</p>
        <div class="mt-4 flex flex-wrap gap-2 text-xs font-medium text-slate-300">
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1">{item.duration}</span>
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1">{item.capacity}</span>
        </div>
        <a
          class="mt-5 inline-flex min-h-11 items-center justify-center rounded-full border border-white/12 px-4 text-sm font-semibold text-[#e2e8f0] transition hover:bg-white/8"
          href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(item.whatsappMessage)}`}
          target="_blank"
          rel="noreferrer"
        >
          Ask availability
        </a>
      </div>
    </article>
  ))}
</div>
