---
import { routes } from "../../data/routes";
import { tours } from "../../data/tours";
import { site } from "../../data/site";

const items = [...routes.slice(0, 2), ...tours.slice(0, 2)];
---

<div class="home-scroll-row home-scroll-row-4 lg:grid lg:grid-cols-4">
  {items.map((item) => (
    <article class="editorial-card home-scroll-card group overflow-hidden rounded-[8px] transition duration-300 hover:-translate-y-1 hover:border-[#f8e7a1]/38">
      <div
        class="route-image-frame visual-placeholder bg-cover bg-center transition duration-500 group-hover:scale-[1.015]"
        role="img"
        aria-label={item.alt}
        style={`background-image: linear-gradient(180deg, rgba(11,12,16,0.05), rgba(11,12,16,0.72)), url('${item.image}');`}
      >
        <div class="flex h-full items-start justify-between p-4">
          <span class="rounded-full border border-white/14 bg-black/28 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{item.category}</span>
          <span class="gold-pill rounded-full px-3 py-1 text-xs font-semibold">{item.priceFrom}</span>
        </div>
      </div>
      <div class="p-4">
        <h3 class="font-[var(--font-editorial-heading)] text-[1.25rem] font-medium leading-tight text-[#f8fafc] sm:text-[1.45rem] lg:text-[1.15rem]">{item.title}</h3>
        <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-400">{item.description}</p>
        <div class="mt-3 flex flex-wrap gap-2 text-xs font-medium text-[#f8e7a1]">
          <span class="rounded-full border border-[#bfa46f]/24 bg-[#064e3b]/24 px-3 py-1">{item.duration}</span>
          <span class="rounded-full border border-[#bfa46f]/24 bg-[#064e3b]/24 px-3 py-1">{item.capacity}</span>
        </div>
        <a
          class="editorial-button-secondary mt-4 min-h-10 px-4"
          href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(item.whatsappMessage)}`}
          target="_blank"
          rel="noreferrer"
        >
          Ask availability
        </a>
      </div>
    </article>
  ))}
</div>
