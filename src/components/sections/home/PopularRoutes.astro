---
import { routes } from "@data/routes";
---

<div class="grid gap-3">
  {routes.map((route) => (
    <article class="rounded-[8px] border border-white/10 bg-white/[0.03] p-4">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0]/56">{route.category}</p>
          <h3 class="mt-1 font-semibold text-[#e2e8f0]">{route.title}</h3>
          <p class="mt-1 text-sm leading-6 text-slate-400">{route.description}</p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-2 text-xs font-semibold text-slate-300 sm:justify-end">
          <span class="rounded-full border border-white/10 px-3 py-1">{route.duration}</span>
          <span class="rounded-full bg-[#e2e8f0] px-3 py-1 text-[#0b0c10]">{route.priceFrom}</span>
        </div>
      </div>
    </article>
  ))}
</div>
