---
const steps = [
  {
    title: "Share your plan",
    description: "Send arrival point, destination, date, passenger count, and preferred tone of service.",
  },
  {
    title: "Confirm the route",
    description: "Match the transfer or tour route with timing, waiting needs, and vehicle category.",
  },
  {
    title: "Ride privately",
    description: "Move with a private driver, clean cabin mood, and direct WhatsApp coordination.",
  },
  {
    title: "Adjust as needed",
    description: "Keep the itinerary flexible for resort timing, weather, food stops, or photo moments.",
  },
];
---

<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
  {steps.map((step, index) => (
    <article class="editorial-card rounded-[8px] p-4 sm:p-5">
      <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[#bfa46f]/38 bg-[#bfa46f]/12 text-xs font-bold text-[#f8e7a1]">
        {String(index + 1).padStart(2, "0")}
      </span>
      <h3 class="mt-4 font-[var(--font-editorial-heading)] text-[1.35rem] font-medium leading-tight text-[#f8fafc]">{step.title}</h3>
      <p class="mt-3 text-sm leading-6 text-slate-400">{step.description}</p>
    </article>
  ))}
</div>
