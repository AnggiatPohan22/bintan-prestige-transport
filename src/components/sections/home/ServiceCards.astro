---
import SwipeControls from "@components/core/SwipeControls.astro";
import { packages } from "@data/packages";
import { site } from "@data/site";

const getPackageHref = (slug: string) => (slug === "taxi-transfer" ? "/packages/pick-up-drop" : `/packages/${slug}`);
---

<div class="home-package-carousel" data-swipe-carousel>
  <div class="home-scroll-row home-scroll-row-2 lg:grid lg:grid-cols-2" data-swipe-track>
    {packages.map((item) => (
      <article class={`package-offer-card package-offer-card--home-service package-offer-card--${item.category} home-scroll-card group`} data-swipe-item>
        <div class="package-offer-card__media service-image-frame">
          <img
            class="package-offer-card__image"
            src={item.image}
            alt={item.alt}
            width="1600"
            height="1000"
            loading="lazy"
            decoding="async"
          />
          <div class="package-offer-card__shade" aria-hidden="true"></div>
          <div class="package-offer-card__badges">
            <span class="package-offer-card__category">{item.category}</span>
            <span class="package-offer-card__price">
              <strong>{item.priceFrom}</strong>
            </span>
          </div>
        </div>
        <div class="package-offer-card__body">
          <div class="package-offer-card__copy">
            <h3 class="package-offer-card__title">{item.title}</h3>
            <p class="package-offer-card__description">{item.description}</p>
          </div>
          <div class="package-offer-card__meta" aria-label="Service basics">
            <span>{item.duration}</span>
            <span>{item.capacity}</span>
          </div>
          <ul class="package-offer-card__highlights" aria-label="Service highlights">
            {item.items.slice(0, 3).map((entry) => (
              <li>{entry.title}</li>
            ))}
          </ul>
          <div class="package-offer-card__actions">
            <a class="package-offer-card__link package-offer-card__link--secondary" href={getPackageHref(item.slug)}>
              Read more
            </a>
            <a
              class="package-offer-card__link package-offer-card__link--primary"
              href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(item.whatsappMessage)}`}
              target="_blank"
              rel="noreferrer"
            >
              Ask availability
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
  <SwipeControls count={packages.length} label="Signature services" className="home-package-dots" />
</div>
