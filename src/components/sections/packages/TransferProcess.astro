---
const steps = [
  {
    title: "Send route details",
    description: "Share pickup, drop-off, date, time, passenger count, and luggage count.",
  },
  {
    title: "Match vehicle fit",
    description: "Choose sedan, MPV, or executive van based on comfort, route, and luggage needs.",
  },
  {
    title: "Confirm timing",
    description: "Lock the schedule and pickup instruction through WhatsApp before the ride.",
  },
  {
    title: "Ride privately",
    description: "Travel with a private driver and direct coordination during the transfer.",
  },
];
---

<div class="relative grid gap-4 md:grid-cols-2 lg:grid-cols-4">
  {steps.map((step, index) => (
    <article class="group relative overflow-hidden rounded-[8px] border border-[#bfa46f]/20 bg-[#071a14]/76 p-5 shadow-[0_20px_62px_rgba(0,0,0,0.24)] transition duration-300 hover:-translate-y-0.5 hover:border-[#f8e7a1]/34">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#f8e7a1]/54 to-transparent"></div>
      <div class="absolute -right-10 -top-12 h-32 w-32 rounded-full bg-[#f8e7a1]/10 blur-3xl transition duration-300 group-hover:bg-[#f8e7a1]/16"></div>
      <div class="relative flex items-start justify-between gap-4">
        <span class="flex h-11 w-11 items-center justify-center rounded-[8px] border border-[#f8e7a1]/42 bg-[#f8e7a1] text-sm font-extrabold text-[#080705] shadow-[0_16px_34px_rgba(214,178,94,0.22)]">{String(index + 1).padStart(2, "0")}</span>
        <span class="mt-2 h-px flex-1 bg-gradient-to-r from-[#f8e7a1]/32 to-transparent lg:mt-5"></span>
      </div>
      <h3 class="relative mt-5 font-[var(--font-editorial-heading)] text-2xl font-medium leading-tight text-[#f8fafc] lg:text-xl">{step.title}</h3>
      <p class="relative mt-3 text-sm leading-6 text-slate-400">{step.description}</p>
    </article>
  ))}
</div>
