---
import SwipeControls from "@components/core/SwipeControls.astro";
import { site } from "@data/site";
import { transportRoutes } from "@data/transportRoutes";
---

<div class="transfer-fleet-carousel" data-swipe-carousel>
  <div class="transfer-fleet-grid grid gap-4 lg:grid-cols-3" data-swipe-track>
    {transportRoutes.map((route) => (
      <article class="fleet-route-card group" data-swipe-item>
        <div class="fleet-route-card__media">
          <img
            class="fleet-route-card__image"
            src={route.image}
            alt={route.alt}
            loading="lazy"
          />
          <div class="fleet-route-card__shade" aria-hidden="true"></div>
          <div class="relative flex h-full items-start justify-between gap-3 p-4">
            <span class="rounded-full border border-white/14 bg-black/28 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[#e2e8f0] backdrop-blur">{route.badge}</span>
            <span class="rounded-full bg-[#f8e7a1] px-3 py-1 text-xs font-extrabold text-[#0b0c10]">{route.priceFrom}</span>
          </div>
        </div>
        <div class="p-5 sm:p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#bfa46f]">{route.badge}</p>
          <h3 class="mt-2 text-xl font-semibold text-[#e2e8f0]">{route.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-400">{route.description}</p>
          <div class="mt-4 space-y-3 text-sm leading-6 text-slate-300">
            <p><span class="font-semibold text-[#f8e7a1]">Destinations:</span> {route.destinations.join(", ")}</p>
            <p><span class="font-semibold text-[#f8e7a1]">Includes:</span> {route.includes.join(", ")}.</p>
          </div>
          <div class="package-offer-card__actions mt-5">
            <a class="package-offer-card__link package-offer-card__link--secondary" href={`/packages/pick-up-drop/${route.slug}`}>
              Read more
            </a>
            <a
              class="package-offer-card__link package-offer-card__link--primary"
              href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent(route.whatsappMessage ?? `Hello, I want to ask about ${route.title}.`)}`}
              target="_blank"
              rel="noreferrer"
            >
              Ask availability
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
  <SwipeControls count={transportRoutes.length} label="Fleet fit routes" breakpoint="tablet" className="transfer-swipe-dots" />
</div>
