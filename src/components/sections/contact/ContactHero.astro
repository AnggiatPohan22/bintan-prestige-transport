---
import { MessageCircle, PhoneCall } from "lucide-react";
import { site } from "@data/site";
import { heroSlides } from "@data/media";
import HeroBackdrop from "@components/core/HeroBackdrop.astro";


---

<section class="contact-hero site-hero-section relative isolate flex min-h-[100svh] overflow-hidden border-b border-white/10 bg-[#0b0c10] text-white">
  <HeroBackdrop images={heroSlides.contact} className="-z-20" />
  <div class="contact-hero__shade absolute inset-0 -z-10"></div>
  <div class="site-hero-inner contact-hero__inner container-page relative flex min-h-[100svh] w-full flex-col justify-end py-12 lg:py-16">
    <div class="hero-copy max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[#e2e8f0]/64">Contact and booking</p>
      <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-[1.05] text-[#e2e8f0] sm:text-5xl lg:text-6xl">
        Tell us your Bintan plan. We will shape the route.
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
        Contact Bintan Prestige for private taxi availability, tour routes, airport or ferry pickup, activity transfers, and custom travel requests across Bintan.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="luxury-btn-primary" href="#whatsapp-planner">
          <MessageCircle className="h-4 w-4" aria-hidden="true" />
          <span>Open Planner</span>
        </a>
        <a class="luxury-btn-secondary" href={`tel:${site.phone}`}>
          <PhoneCall className="h-4 w-4" aria-hidden="true" />
          <span>Call</span>
        </a>
      </div>
    </div>

  </div>
</section>
